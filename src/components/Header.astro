---
import type { NavLink } from '../data/home';
import { serviceCards } from '../data/home';

interface Props {
	links: NavLink[];
	topBarLabel?: string;
	topBarAddress?: string;
	ctaHref?: string;
}

const {
	links,
	topBarLabel = 'Northamptonshire Electrical Contractors',
	topBarAddress = '81A Charles Street, Kettering, Northants, NN16 9RL',
	ctaHref = '#contact',
} = Astro.props;

const serviceMenuItems = serviceCards.map((service) => ({
	title: service.title,
	description: service.description,
	href: service.href ?? '/#services',
	image: service.image,
}));

serviceMenuItems.push({
	title: 'Custom Electrical Work',
	description: 'Submit a custom project request.',
	href: '/custom-electrical-work/',
	image: '/images/service-design-technical.jpg',
});
---

<div class="site-header">
	<div class="top-bar">
		<div class="top-bar-inner">
			<p>{topBarLabel}</p>
			<p>{topBarAddress}</p>
		</div>
	</div>

	<div class="nav-wrap">
		<nav class="top-nav" aria-label="Main navigation">
			<a href="/" class="brand" aria-label="NEC Ltd Electrical home">
				<img src="/images/logo-blue.svg" alt="NEC Ltd Electrical" width="240" height="40" />
			</a>

			<div class="nav-actions">
				<ul class="nav-list">
					{
						links.map((link) =>
							link.label === 'Services' ? (
								<li class="has-mega-menu" data-services-menu>
									<a href={link.href} class="services-trigger" aria-haspopup="true" aria-expanded="false" data-services-trigger>Services</a>
									<div class="mega-menu" role="group" aria-label="Service overview menu" data-services-panel>
										<p class="mega-title">Service Overview</p>
										<div class="mega-grid">
											{
												serviceMenuItems.map((item) => (
													<article class="mega-item">
														<a class:list={['mega-link', item.href === '/custom-electrical-work/' && 'mega-link-featured']} href={item.href}>
															<img class="mega-thumb" src={item.image} alt="" loading="lazy" width="80" height="56" />
															<span class="mega-copy">
																<span class="mega-item-title">{item.title}</span>
																<span class="mega-item-desc">{item.description}</span>
															</span>
														</a>
													</article>
												))
											}
										</div>
									</div>
								</li>
							) : (
								<li>
									<a href={link.href}>{link.label}</a>
								</li>
							),
						)
					}
				</ul>

				<a href={ctaHref} class="btn btn-primary header-quote-btn">Get a Quote</a>

				<button
					type="button"
					class="menu-toggle"
					aria-expanded="false"
					aria-controls="site-mobile-nav"
					data-menu-toggle
				>
					<span class="menu-toggle-bars" aria-hidden="true"></span>
					<span class="visually-hidden">Open menu</span>
				</button>
			</div>
		</nav>

		<div
			class="mobile-drawer"
			id="site-mobile-nav"
			data-mobile-drawer
			aria-hidden="true"
			inert
		>
			<button type="button" class="mobile-drawer-backdrop" aria-label="Close menu" data-menu-close></button>
			<div class="mobile-drawer-panel">
				<nav class="mobile-drawer-nav" aria-label="Mobile menu">
					{
						links.map((link) =>
							link.label === 'Services' ? (
								<div class="mobile-drawer-group">
									<a class="mobile-cta-link mobile-cta-link-services" href={link.href}>
										<span class="mobile-cta-title">Services overview</span>
										<span class="mobile-cta-hint">All capabilities</span>
									</a>
									<div class="mobile-service-nest">
										<p class="mobile-drawer-subheading">Service pages</p>
										<ul class="mobile-service-list">
											{serviceMenuItems.map((item) => (
												<li>
													<a
														class:list={['mobile-cta-link', 'mobile-cta-link-compact', item.href === '/custom-electrical-work/' && 'mobile-cta-featured']}
														href={item.href}
													>
														<span class="mobile-cta-title">{item.title}</span>
														<span class="mobile-cta-hint">{item.description}</span>
													</a>
												</li>
											))}
										</ul>
									</div>
								</div>
							) : (
								<a class="mobile-cta-link" href={link.href}>
									<span class="mobile-cta-title">{link.label}</span>
								</a>
							),
						)
					}
					<a href={ctaHref} class="btn btn-primary mobile-quote-cta">Get a Quote</a>
				</nav>
			</div>
		</div>
	</div>
</div>

<script is:inline>
	const serviceMenus = document.querySelectorAll('[data-services-menu]');

	serviceMenus.forEach((menu) => {
		const trigger = menu.querySelector('[data-services-trigger]');
		const panel = menu.querySelector('[data-services-panel]');
		if (!trigger || !panel) return;

		let closeTimer;

		const openMenu = () => {
			if (closeTimer) {
				window.clearTimeout(closeTimer);
				closeTimer = undefined;
			}
			menu.classList.add('is-open');
			trigger.setAttribute('aria-expanded', 'true');
		};

		const closeMenu = () => {
			closeTimer = window.setTimeout(() => {
				menu.classList.remove('is-open');
				trigger.setAttribute('aria-expanded', 'false');
			}, 260);
		};

		trigger.addEventListener('mouseenter', openMenu);
		panel.addEventListener('mouseenter', openMenu);
		menu.addEventListener('mouseleave', closeMenu);
		menu.addEventListener('focusin', openMenu);
		menu.addEventListener('focusout', (event) => {
			const next = event.relatedTarget;
			if (next && menu.contains(next)) return;
			closeMenu();
		});
	});

	let mobileNavAbort;
	const initMobileNav = () => {
		const header = document.querySelector('.site-header');
		const toggle = document.querySelector('[data-menu-toggle]');
		const drawer = document.querySelector('[data-mobile-drawer]');
		if (!header || !toggle || !drawer) return;

		mobileNavAbort?.abort();
		mobileNavAbort = new AbortController();
		const { signal } = mobileNavAbort;

		const label = toggle.querySelector('.visually-hidden');
		const backdrop = drawer.querySelector('[data-menu-close]');

		const setDrawerOffset = () => {
			const bottom = Math.ceil(header.getBoundingClientRect().bottom);
			drawer.style.setProperty('--drawer-panel-top', `${bottom + 6}px`);
		};

		const setOpen = (open) => {
			drawer.classList.toggle('is-open', open);
			header.classList.toggle('is-mobile-nav-open', open);
			toggle.setAttribute('aria-expanded', String(open));
			drawer.setAttribute('aria-hidden', String(!open));
			if (open) {
				drawer.removeAttribute('inert');
				setDrawerOffset();
				document.body.style.overflow = 'hidden';
				if (label) label.textContent = 'Close menu';
			} else {
				drawer.setAttribute('inert', '');
				document.body.style.overflow = '';
				if (label) label.textContent = 'Open menu';
			}
		};

		toggle.addEventListener(
			'click',
			() => {
				setOpen(!drawer.classList.contains('is-open'));
			},
			{ signal },
		);

		backdrop?.addEventListener('click', () => setOpen(false), { signal });

		drawer.querySelectorAll('a').forEach((anchor) => {
			anchor.addEventListener('click', () => setOpen(false), { signal });
		});

		document.addEventListener(
			'keydown',
			(event) => {
				if (event.key === 'Escape' && drawer.classList.contains('is-open')) {
					setOpen(false);
				}
			},
			{ signal },
		);

		window.addEventListener(
			'resize',
			() => {
				if (window.innerWidth > 1120 && drawer.classList.contains('is-open')) {
					setOpen(false);
				} else if (drawer.classList.contains('is-open')) {
					setDrawerOffset();
				}
			},
			{ signal },
		);
	};

	initMobileNav();
	document.addEventListener('astro:page-load', initMobileNav);
</script>

<style>
	.site-header {
		position: relative;
		z-index: 5;
	}

	.site-header.is-mobile-nav-open {
		z-index: 200;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip-path: inset(50%);
		white-space: nowrap;
		border: 0;
	}

	.top-bar {
		background: var(--blue);
		color: var(--white);
	}

	.top-bar-inner {
		width: min(100% - 2rem, 1400px);
		margin-inline: auto;
		min-height: 2.05rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font: 400 0.8rem/1 'League Spartan', Arial, sans-serif;
		letter-spacing: 0.02em;
	}

	.top-bar-inner p {
		margin: 0;
	}

	.nav-wrap {
		position: relative;
		width: min(100% - 2rem, 1400px);
		max-width: 100%;
		box-sizing: border-box;
		margin: 0.85rem auto 0;
		padding-inline: env(safe-area-inset-left, 0px) env(safe-area-inset-right, 0px);
	}

	.menu-toggle {
		display: none;
		position: relative;
		align-items: center;
		justify-content: center;
		width: 2.85rem;
		height: 2.85rem;
		padding: 0;
		border: 0;
		background: rgba(0, 0, 254, 0.06);
		color: var(--charcoal-100);
		cursor: pointer;
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		transition: background-color 0.2s var(--motion-ease);
	}

	.menu-toggle:hover {
		background: rgba(0, 0, 254, 0.12);
	}

	.menu-toggle-bars {
		position: relative;
		width: 1.35rem;
		height: 2px;
		background: currentColor;
		border-radius: 1px;
		transition: background 0.2s var(--motion-ease);
	}

	.menu-toggle-bars::before,
	.menu-toggle-bars::after {
		content: '';
		position: absolute;
		left: 0;
		width: 100%;
		height: 2px;
		background: currentColor;
		border-radius: 1px;
		transition: transform 0.2s var(--motion-ease);
	}

	.menu-toggle-bars::before {
		top: -7px;
	}

	.menu-toggle-bars::after {
		top: 7px;
	}

	.site-header.is-mobile-nav-open .menu-toggle-bars {
		background: transparent;
	}

	.site-header.is-mobile-nav-open .menu-toggle-bars::before {
		transform: translateY(7px) rotate(45deg);
	}

	.site-header.is-mobile-nav-open .menu-toggle-bars::after {
		transform: translateY(-7px) rotate(-45deg);
	}

	.mobile-drawer {
		position: fixed;
		inset: 0;
		z-index: 60;
		overflow-x: clip;
		pointer-events: none;
		visibility: hidden;
		opacity: 0;
		transition: opacity 0.25s var(--motion-ease), visibility 0.25s var(--motion-ease);
	}

	.mobile-drawer.is-open {
		pointer-events: auto;
		visibility: visible;
		opacity: 1;
	}

	/* Start below the header so the dim layer does not wash over the menu / close control */
	.mobile-drawer-backdrop {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		top: var(--drawer-panel-top, 100vh);
		z-index: 0;
		background: rgba(17, 22, 35, 0.45);
		border: 0;
		padding: 0;
		cursor: pointer;
	}

	.mobile-drawer-panel {
		position: absolute;
		left: 50%;
		top: var(--drawer-panel-top, 120px);
		z-index: 1;
		width: min(520px, calc(100% - 1.25rem));
		box-sizing: border-box;
		max-height: min(78vh, calc(100dvh - var(--drawer-panel-top, 120px) - 12px), 560px);
		overflow-y: auto;
		overflow-x: hidden;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: thin;
		scrollbar-color: var(--blue) rgba(0, 0, 254, 0.08);
		background: var(--white);
		border: 1px solid rgba(18, 22, 38, 0.08);
		box-shadow: 0 24px 48px rgba(18, 22, 38, 0.22);
		clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 0 100%);
		transform: translateX(-50%) translateY(-8px);
		opacity: 0;
		transition: opacity 0.22s var(--motion-ease), transform 0.22s var(--motion-ease);
	}

	.mobile-drawer-panel::-webkit-scrollbar {
		width: 9px;
	}

	.mobile-drawer-panel::-webkit-scrollbar-track {
		margin-block: 6px;
		background: rgba(30, 36, 56, 0.06);
		border-radius: 100px;
	}

	.mobile-drawer-panel::-webkit-scrollbar-thumb {
		background: linear-gradient(180deg, #2a32ff 0%, var(--blue) 45%, #0000c4 100%);
		border-radius: 100px;
		border: 2px solid var(--white);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.2);
	}

	.mobile-drawer-panel::-webkit-scrollbar-thumb:hover {
		background: linear-gradient(180deg, #3d44ff 0%, #1b22ff 100%);
	}

	.mobile-drawer.is-open .mobile-drawer-panel {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}

	.mobile-drawer-nav {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		padding: 1rem 1rem 1.15rem;
	}

	.mobile-drawer-group {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.mobile-service-nest {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-top: 0.1rem;
		margin-left: 0.65rem;
		padding-left: 0.85rem;
		border-left: 2px solid rgba(0, 0, 254, 0.2);
	}

	.mobile-drawer-subheading {
		margin: 0;
		padding: 0 0.1rem 0 0;
		font: 600 0.72rem/1 'Open Sans', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--blue);
	}

	.mobile-service-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.mobile-cta-link {
		display: block;
		padding: 0.78rem 0.95rem;
		background: #f5f7fb;
		color: var(--charcoal-100);
		text-decoration: none;
		clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 0 100%);
		transition: background-color 0.2s var(--motion-ease), color 0.2s var(--motion-ease), transform 0.2s
			var(--motion-ease);
	}

	.mobile-cta-link:hover {
		background: var(--blue);
		color: var(--white);
		transform: translateY(-1px);
	}

	.mobile-cta-title {
		display: block;
		font: 700 1.05rem/1.15 'League Spartan', Arial, sans-serif;
	}

	.mobile-cta-hint {
		display: block;
		margin-top: 0.32rem;
		font: 400 0.88rem/1.45 'Open Sans', Arial, sans-serif;
		color: var(--charcoal-400);
	}

	.mobile-cta-link:hover .mobile-cta-hint {
		color: rgba(255, 255, 255, 0.92);
	}

	.mobile-cta-link-compact {
		padding: 0.62rem 0.88rem;
	}

	.mobile-cta-link-compact .mobile-cta-title {
		font-size: 0.98rem;
	}

	.mobile-cta-link-compact .mobile-cta-hint {
		font-size: 0.82rem;
		margin-top: 0.22rem;
	}

	.mobile-cta-featured {
		background: var(--blue);
		color: var(--white);
	}

	.mobile-cta-featured .mobile-cta-hint {
		color: rgba(255, 255, 255, 0.9);
	}

	.mobile-cta-featured:hover {
		background: #1b22ff;
		color: var(--white);
	}

	.mobile-quote-cta {
		margin-top: 0.25rem;
		width: 100%;
		justify-content: center;
		text-align: center;
	}

	@media (prefers-reduced-motion: reduce) {
		.mobile-drawer,
		.mobile-drawer-panel,
		.menu-toggle-bars,
		.menu-toggle-bars::before,
		.menu-toggle-bars::after {
			transition-duration: 0.01ms;
		}
	}

	.top-nav {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 2rem;
		position: relative;
		min-width: 0;
		max-width: 100%;
		box-sizing: border-box;
		background: rgba(255, 255, 255, 0.95);
		padding: 0.9rem 1rem;
		border: 1px solid rgba(255, 255, 255, 0.65);
		clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
		overflow-x: clip;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		min-width: 0;
		max-width: 100%;
	}

	.brand img {
		display: block;
		width: auto;
		max-width: 100%;
		height: auto;
		max-height: 2.35rem;
		object-fit: contain;
		object-position: left center;
	}

	.nav-actions {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		justify-self: end;
		flex-shrink: 0;
	}

	.nav-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		justify-content: center;
		gap: 1.2rem;
		font: 400 1.05rem/1 'League Spartan', Arial, sans-serif;
		justify-self: end;
	}

	.nav-list > li > a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.52rem 0.75rem;
		color: var(--charcoal-100);
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		transition: background-color 0.2s var(--motion-ease), color 0.2s var(--motion-ease), transform 0.2s
			var(--motion-ease);
	}

	.nav-list > li > a:hover {
		background: var(--blue);
		color: var(--white);
		transform: translateY(-1px);
	}

	.has-mega-menu {
		position: static;
		display: inline-flex;
		align-items: center;
	}

	.services-trigger::after {
		content: '';
		width: 0.4rem;
		height: 0.4rem;
		margin-left: 0.4rem;
		border-right: 2px solid currentColor;
		border-bottom: 2px solid currentColor;
		transform: rotate(45deg) translateY(-1px);
	}

	.services-trigger {
		font: 400 1.05rem/1 'League Spartan', Arial, sans-serif;
		letter-spacing: normal;
	}

	.mega-menu {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(4px);
		width: min(860px, calc(100vw - 2.5rem));
		background: var(--white);
		border: 1px solid rgba(18, 22, 38, 0.08);
		box-shadow: 0 18px 42px rgba(18, 22, 38, 0.16);
		padding: 1rem;
		clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 0.2s var(--motion-ease), transform 0.2s var(--motion-ease),
			visibility 0.2s var(--motion-ease);
		z-index: 20;
	}

	/* Invisible bridge to keep hover alive from trigger to panel */
	.mega-menu::before {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		top: -14px;
		height: 14px;
	}

	.has-mega-menu:hover .mega-menu,
	.has-mega-menu.is-open .mega-menu,
	.has-mega-menu:focus-within .mega-menu {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transform: translateX(-50%) translateY(0);
	}

	.mega-title {
		margin: 0;
		font: 600 0.82rem/1 'Open Sans', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--blue);
	}

	.mega-grid {
		margin-top: 0.75rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.6rem;
	}

	.mega-item {
		margin: 0;
	}

	.mega-link {
		display: block;
		margin: 0;
		padding: 0.62rem 0.66rem;
		display: grid;
		grid-template-columns: 76px 1fr;
		align-items: start;
		gap: 0.72rem;
		background: #f5f7fb;
		color: var(--charcoal-200);
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		transition: transform 0.2s var(--motion-ease), background-color 0.2s var(--motion-ease), color 0.2s
			var(--motion-ease);
	}

	.mega-item-title {
		display: block;
		font: 700 1.06rem/1.08 'League Spartan', Arial, sans-serif;
		color: var(--charcoal-100);
	}

	.mega-copy {
		display: block;
	}

	.mega-item-desc {
		display: block;
		margin-top: 0.33rem;
		font: 400 0.95rem/1.45 'Open Sans', Arial, sans-serif;
		color: var(--charcoal-400);
		max-width: 31ch;
	}

	.mega-thumb {
		width: 100%;
		height: 3.8rem;
		object-fit: cover;
		object-position: center;
		clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 0 100%);
	}

	@media (max-width: 900px) {
		.mega-grid {
			grid-template-columns: 1fr;
		}
	}

	.mega-link:hover {
		background: var(--blue);
		color: var(--white);
		transform: translateY(-1px);
	}

	.mega-link:hover .mega-item-desc {
		color: rgba(255, 255, 255, 0.9);
	}

	.mega-link:hover .mega-item-title {
		color: var(--white);
	}

	.mega-link-featured {
		background: var(--blue);
