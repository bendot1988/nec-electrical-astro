---
import type { NavLink } from '../data/home';

interface Props {
	links: NavLink[];
	topBarLabel?: string;
	topBarAddress?: string;
}

const {
	links,
	topBarLabel = 'Northamptonshire Electrical Contractors',
	topBarAddress = '81A Charles Street, Kettering, Northants, NN16 9RL',
} = Astro.props;
---

<div class="site-header">
	<div class="top-bar">
		<div class="top-bar-inner">
			<p>{topBarLabel}</p>
			<p>{topBarAddress}</p>
		</div>
	</div>

	<div class="nav-wrap">
		<nav class="top-nav" aria-label="Main navigation">
			<a href="/" class="brand" aria-label="NEC Ltd Electrical home">
				<img src="/images/logo-blue.svg" alt="NEC Ltd Electrical" width="240" height="40" />
			</a>

			<div class="nav-actions">
				<ul class="nav-list">
					{
						links.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))
					}
				</ul>

				<a href="#contact" class="btn btn-primary">Get a Quote</a>
			</div>
		</nav>
	</div>
</div>

<style>
	.site-header {
		position: relative;
		z-index: 5;
	}

	.top-bar {
		background: var(--blue);
		color: var(--white);
	}

	.top-bar-inner {
		width: min(100% - 2rem, 1400px);
		margin-inline: auto;
		min-height: 2.05rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font: 400 0.8rem/1 'League Spartan', Arial, sans-serif;
		letter-spacing: 0.02em;
	}

	.top-bar-inner p {
		margin: 0;
	}

	.nav-wrap {
		width: min(100% - 2rem, 1400px);
		margin: 0.85rem auto 0;
	}

	.top-nav {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 2rem;
		background: rgba(255, 255, 255, 0.95);
		padding: 0.9rem 1rem;
		border-radius: 0.85rem;
		border: 1px solid rgba(255, 255, 255, 0.65);
	}

	.brand {
		display: inline-flex;
		align-items: center;
	}

	.nav-actions {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		justify-self: end;
	}

	.nav-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 1.2rem;
		font: 400 1.05rem/1 'League Spartan', Arial, sans-serif;
		justify-self: end;
	}

	.nav-list a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.52rem 0.75rem;
		color: var(--charcoal-100);
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		transition: background-color 0.2s var(--motion-ease), color 0.2s var(--motion-ease), transform 0.2s
			var(--motion-ease);
	}

	.nav-list a:hover {
		background: var(--blue);
		color: var(--white);
		transform: translateY(-1px);
	}

	@media (max-width: 1120px) {
		.nav-list {
			display: none;
		}
	}

	@media (max-width: 900px) {
		.top-bar-inner {
			font-size: 0.75rem;
		}

		.top-nav {
			grid-template-columns: auto 1fr;
			gap: 1rem;
			justify-content: space-between;
		}

		.nav-actions {
			justify-self: end;
		}
	}

	@media (max-width: 640px) {
		.top-bar-inner {
			flex-direction: column;
			align-items: flex-start;
			justify-content: center;
			padding: 0.4rem 0;
			gap: 0.3rem;
		}

		.nav-wrap {
			width: min(100% - 1rem, 1400px);
		}

		.top-nav {
			padding: 0.75rem;
			border-radius: 0.6rem;
		}

		.top-nav .btn {
			font-size: 0.9rem;
			padding-inline: 1rem;
		}
	}
</style>
