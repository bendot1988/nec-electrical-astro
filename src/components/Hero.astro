---
import Header from './Header.astro';
import type { NavLink } from '../data/home';

interface Props {
	links: NavLink[];
}

const { links } = Astro.props;
---

<header class="hero">
	<div class="hero-bg hero-bg-1" aria-hidden="true"></div>
	<div class="hero-bg hero-bg-2" aria-hidden="true"></div>
	<div class="hero-bg hero-bg-3" aria-hidden="true"></div>
	<div class="hero-overlay" aria-hidden="true"></div>

	<Header links={links} />

	<div class="container hero-content">
		<div class="hero-text" data-animate="fade-left">
			<p class="eyebrow" data-animate="fade-up" data-animate-delay="0.08">Northamptonshire Electrical Contractors</p>
			<h1 data-animate="fade-up" data-animate-delay="0.14">Professional Design & Build Electrical Services</h1>
			<p data-animate="fade-up" data-animate-delay="0.2">
				Delivering fully supported electrical installations from design to completion for industrial, commercial,
				and educational sectors.
			</p>
			<div class="hero-actions" data-animate="fade-up" data-animate-delay="0.26">
				<a href="/#contact" class="btn btn-primary">Start Your Project Enquiry</a>
				<a href="/#services" class="btn btn-outline">Our Expertise</a>
			</div>
			<div class="hero-accreditations" data-animate="fade-up" data-animate-delay="0.3">
				<img src="/images/logo-chas-accredited.png" alt="CHAS Accredited Contractor" loading="lazy" width="310" height="172" />
				<img src="/images/logo-niceic-approved.png" alt="NICEIC Approved Contractor" loading="lazy" width="300" height="170" />
			</div>
		</div>
	</div>
</header>

<style>
	.hero {
		position: relative;
		min-height: 85vh;
		isolation: isolate;
		overflow: clip;
		background: #000;
	}

	.hero-bg,
	.hero-overlay {
		position: absolute;
		inset: 0;
	}

	.hero-bg {
		background-color: #000;
		background-size: cover;
		background-position: center;
		opacity: 0;
		animation: heroFade 18s linear infinite;
		will-change: opacity;
	}

	.hero-bg-1 {
		background-image: url('/images/hero-1.jpg');
		animation-delay: 0s;
	}

	.hero-bg-2 {
		background-image: url('/images/hero-2.jpg');
		animation-delay: 6s;
	}

	.hero-bg-3 {
		background-image: url('/images/hero-3.jpg');
		animation-delay: 12s;
	}

	.hero-overlay {
		background: linear-gradient(130deg, rgba(24, 24, 31, 0.8), rgba(24, 24, 31, 0.45));
	}

	.hero-content {
		position: relative;
		z-index: 1;
		min-height: calc(85vh - 6.5rem);
		display: flex;
		align-items: center;
	}

	.hero-text {
		max-width: 62ch;
		align-self: center;
		color: var(--white);
		padding: 3rem 0 4rem;
	}

	.eyebrow {
		text-transform: uppercase;
		font: 600 0.75rem/1.2 'Open Sans', Arial, sans-serif;
		letter-spacing: 0.07em;
	}

	h1 {
		margin-top: 1.1rem;
		font-size: clamp(2.3rem, 7vw, 4.5rem);
		color: var(--white);
		line-height: 1;
		letter-spacing: -0.03em;
	}

	.hero-text p + p {
		margin-top: 1.15rem;
	}

	.hero-actions {
		margin-top: 2rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.hero-accreditations {
		margin-top: 1.55rem;
		display: flex;
		flex-wrap: nowrap;
		gap: 0.7rem;
		align-items: center;
	}

	.hero-accreditations img {
		display: block;
		height: 48px;
		width: auto;
		background: rgba(255, 255, 255, 0.92);
		padding: 0.32rem 0.5rem;
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		box-shadow: 0 8px 18px rgba(14, 19, 35, 0.22);
		transition: transform 0.2s var(--motion-ease), box-shadow 0.2s var(--motion-ease), background-color 0.2s
			var(--motion-ease);
	}

	.hero-accreditations img:hover {
		transform: translateY(-3px);
		box-shadow: 0 14px 24px rgba(14, 19, 35, 0.32);
		background: #ffffff;
	}

	@keyframes heroFade {
		0% {
			opacity: 0;
		}
		8%,
		30% {
			opacity: 1;
		}
		41.333%,
		100% {
			opacity: 0;
		}
	}
</style>
