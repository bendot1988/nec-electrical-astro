---
import type { NavLink } from '../data/home';

interface Props {
	links: NavLink[];
}

const { links } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer id="locations" class="site-footer">
	<div class="container footer-grid">
		<div class="footer-col">
			<img src="/images/logo-white.svg" alt="NEC Ltd Electrical" width="170" height="42" />
			<p>
				NICEIC Approved Contractor delivering high-quality design and build electrical services for the
				industrial, commercial, and educational sectors.
			</p>
		</div>
		<div class="footer-col">
			<h3>Useful Links</h3>
			<ul>
				<li><a href="/">Home</a></li>
				<li><a href="/sitemap/">Site map</a></li>
				{
					links.map((link) => (
						<li>
							<a href={link.href}>{link.label}</a>
						</li>
					))
				}
			</ul>
		</div>
		<div class="footer-col">
			<h3>Contact Us</h3>
			<ul>
				<li>
					<span class="contact-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M22 16.92V20a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 11.2 18.8 19.5 19.5 0 0 1 5.2 12.8 19.86 19.86 0 0 1 2 4.18 2 2 0 0 1 4 2h3.09a2 2 0 0 1 2 1.72c.12.9.34 1.79.66 2.63a2 2 0 0 1-.45 2.11L8 9.8a16 16 0 0 0 6.2 6.2l1.34-1.3a2 2 0 0 1 2.11-.45c.84.32 1.73.54 2.63.66A2 2 0 0 1 22 16.92Z" />
						</svg>
					</span>
					<a href="tel:+441536417807">01536 417 807</a>
				</li>
				<li>
					<span class="contact-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 21s7-5.4 7-11a7 7 0 1 0-14 0c0 5.6 7 11 7 11Z" />
							<circle cx="12" cy="10" r="2.3" />
						</svg>
					</span>
					81A Charles Street, Kettering, Northants, NN16 9RL
				</li>
			</ul>
		</div>
	</div>
	<div class="container footer-bottom">
		<p class="footer-copyright">© {currentYear} NEC Ltd Electrical. All rights reserved.</p>
		<nav class="footer-legal" aria-label="Legal links">
			<a href="/privacy">Privacy</a>
			<a href="/terms">Terms</a>
			<a href="/cookies">Cookies</a>
		</nav>
		<p class="footer-credit">
			<a href="https://dotwall.dev/" target="_blank" rel="noopener noreferrer">dotwall</a>
		</p>
	</div>
</footer>

<style>
	.site-footer {
		--footer-divider: rgba(143, 149, 171, 0.28);
		position: relative;
		isolation: isolate;
		overflow: hidden;
		background: #111320 url('/images/uk-dots-map.png');
		background-repeat: no-repeat;
		background-position: center;
		background-size: cover;
		padding: 0;
		color: var(--white);
		font-size: 1.02rem;
		margin-top: -1px;
	}

	.site-footer::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(145deg, rgba(19, 20, 33, 0.96), rgba(24, 24, 44, 0.96));
		pointer-events: none;
		z-index: 0;
	}

	.site-footer::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		top: -2px;
		height: 3px;
		background: linear-gradient(145deg, rgba(19, 20, 33, 0.96), rgba(24, 24, 44, 0.96));
		pointer-events: none;
		z-index: 1;
	}

	.footer-grid,
	.footer-bottom {
		position: relative;
		z-index: 1;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 1.4rem;
		border-bottom: 1px solid var(--footer-divider);
	}

	h3 {
		color: var(--white);
		font-size: 1.2rem;
	}

	p {
		margin-top: 0.9rem;
		max-width: 44ch;
	}

	ul {
		margin: 0.9rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.45rem;
	}

	.footer-col:last-child li {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: start;
		column-gap: 0.7rem;
	}

	.site-footer a {
		display: inline-flex;
		align-items: center;
		padding: 0.24rem 0.5rem;
		margin-inline: -0.5rem;
		color: inherit;
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		transition: transform 0.2s var(--motion-ease), background-color 0.2s var(--motion-ease), color 0.2s
			var(--motion-ease);
	}

	.site-footer a:hover {
		background: var(--blue);
		color: var(--white);
		transform: translateY(-1px);
	}

	.footer-col {
		padding: 2.5rem 0;
	}

	.contact-icon {
		color: #9cb8ff;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.9rem;
		height: 1.9rem;
		background: rgba(156, 184, 255, 0.14);
		border: 1px solid rgba(156, 184, 255, 0.28);
		clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 0 100%);
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.45rem;
		padding: 0.28rem 0;
		font-size: 0.76rem;
		line-height: 1.2;
		color: var(--white);
		border-top: 1px solid var(--footer-divider);
	}

	.footer-bottom p {
		margin: 0;
	}

	.footer-legal {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
	}

	.footer-legal a {
		color: inherit;
	}

	.footer-legal a + a {
		padding-left: 0.55rem;
		border-left: 1px solid var(--footer-divider);
	}

	.footer-credit a {
		color: var(--white);
		text-decoration: none;
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}

		.footer-col + .footer-col {
			border-left: 0;
			border-top: 1px solid var(--footer-divider);
		}

		.footer-bottom {
			flex-direction: column;
			gap: 0.14rem;
			align-items: flex-start;
			padding: 0.24rem 0;
		}

		.footer-legal {
			flex-wrap: wrap;
		}
	}
</style>
