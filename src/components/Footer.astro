---
import type { NavLink } from '../data/home';

interface Props {
	links: NavLink[];
}

const { links } = Astro.props;
---

<footer id="locations" class="site-footer">
	<div class="container footer-grid">
		<div class="footer-col">
			<img src="/images/logo-white.svg" alt="NEC Ltd Electrical" width="170" height="42" />
			<p>
				NICEIC Approved Contractor delivering high-quality design and build electrical services for the
				industrial, commercial, and educational sectors.
			</p>
		</div>
		<div class="footer-col">
			<h3>Useful Links</h3>
			<ul>
				<li><a href="/">Home</a></li>
				{
					links.map((link) => (
						<li>
							<a href={link.href}>{link.label}</a>
						</li>
					))
				}
			</ul>
		</div>
		<div class="footer-col">
			<h3>Contact Us</h3>
			<ul>
				<li>
					<span class="contact-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M22 16.92V20a2 2 0 0 1-2.18 2A19.86 19.86 0 0 1 11.2 18.8 19.5 19.5 0 0 1 5.2 12.8 19.86 19.86 0 0 1 2 4.18 2 2 0 0 1 4 2h3.09a2 2 0 0 1 2 1.72c.12.9.34 1.79.66 2.63a2 2 0 0 1-.45 2.11L8 9.8a16 16 0 0 0 6.2 6.2l1.34-1.3a2 2 0 0 1 2.11-.45c.84.32 1.73.54 2.63.66A2 2 0 0 1 22 16.92Z" />
						</svg>
					</span>
					<a href="tel:+441536417807">01536 417 807</a>
				</li>
				<li>
					<span class="contact-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 21s7-5.4 7-11a7 7 0 1 0-14 0c0 5.6 7 11 7 11Z" />
							<circle cx="12" cy="10" r="2.3" />
						</svg>
					</span>
					81A Charles Street, Kettering, Northants, NN16 9RL
				</li>
			</ul>
		</div>
	</div>
	<div class="container footer-bottom">
		<p>dotwall</p>
		<p>Terms of Use | Privacy Policy</p>
	</div>
</footer>

<style>
	.site-footer {
		background:
			linear-gradient(145deg, rgba(19, 20, 33, 0.96), rgba(24, 24, 44, 0.96)),
			url('/images/uk-dots-map.png');
		background-repeat: no-repeat;
		background-position: center;
		background-size: cover;
		padding: 0;
		color: #d1d4e1;
		border-top: 1px solid rgba(255, 255, 255, 0.12);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
	}

	h3 {
		color: var(--white);
		font-size: 1.05rem;
	}

	p {
		margin-top: 0.9rem;
		max-width: 44ch;
	}

	ul {
		margin: 0.9rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.45rem;
	}

	.footer-col:last-child li {
		display: flex;
		align-items: flex-start;
	}

	a:hover {
		color: var(--white);
	}

	.footer-col {
		padding: 2.5rem 1.6rem;
	}

	.footer-col + .footer-col {
		border-left: 1px solid rgba(255, 255, 255, 0.12);
	}

	.contact-icon {
		color: var(--blue);
		display: inline-flex;
		align-items: center;
		margin-right: 0.4rem;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.9rem 1.6rem;
		font-size: 0.85rem;
		color: #8f95ab;
	}

	.footer-bottom p {
		margin: 0;
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}

		.footer-col + .footer-col {
			border-left: 0;
			border-top: 1px solid rgba(255, 255, 255, 0.12);
		}

		.footer-bottom {
			flex-direction: column;
			gap: 0.4rem;
			align-items: flex-start;
		}
	}
</style>
