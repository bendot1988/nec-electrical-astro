---
const filters = [
	{ value: 'all', label: 'All Services' },
	{ value: 'design', label: 'Design & Technical' },
	{ value: 'power', label: 'Power Infrastructure' },
	{ value: 'lighting', label: 'Lighting Systems' },
	{ value: 'security', label: 'Security & Safety' },
	{ value: 'data', label: 'Data & Communications' },
];
---

<div class="filter-wrap" data-service-filter>
	<p class="filter-label">Filter services</p>
	<div class="filter-buttons" role="toolbar" aria-label="Service categories">
		{
			filters.map((filter, index) => (
				<button
					type="button"
					class="filter-btn"
					data-filter={filter.value}
					aria-pressed={index === 0 ? 'true' : 'false'}
				>
					{filter.label}
				</button>
			))
		}
	</div>
</div>

<style>
	.filter-wrap {
		margin-top: 1.25rem;
	}

	.filter-label {
		font: 600 0.9rem/1 'League Spartan', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--charcoal-400);
	}

	.filter-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 0.7rem;
	}

	.filter-btn {
		border: 1px solid #ced4e2;
		background: var(--white);
		color: var(--charcoal-300);
		font: 600 0.9rem/1 'League Spartan', Arial, sans-serif;
		padding: 0.6rem 0.8rem;
		border-radius: 0;
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		cursor: pointer;
		transition: transform 0.2s var(--motion-ease), background-color 0.2s var(--motion-ease), border-color 0.2s
			var(--motion-ease), color 0.2s var(--motion-ease);
	}

	.filter-btn:hover {
		border-color: var(--blue);
		background: var(--blue);
		color: var(--white);
		transform: translateY(-1px);
	}

	.filter-btn.is-active {
		background: var(--blue);
		color: var(--white);
		border-color: var(--blue);
	}
</style>
