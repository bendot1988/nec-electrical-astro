---
interface FaqItem {
	question: string;
	answer: string;
}

interface Props {
	kicker?: string;
	title?: string;
	items: FaqItem[];
}

const { kicker = 'Common questions', title = 'Frequently Asked Questions', items } = Astro.props;
---

<section class="section service-faq">
	<div class="container faq-inner">
		<p class="section-kicker">
			<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
				<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"></circle>
				<path d="M9.8 9.2a2.4 2.4 0 0 1 4.8 0c0 1.8-2.4 2.2-2.4 3.7" fill="none" stroke="currentColor" stroke-width="2"></path>
				<circle cx="12" cy="17.2" r="1.05" fill="currentColor"></circle>
			</svg>
			{kicker}
		</p>
		<h2 class="section-title">{title}</h2>

		<div class="faq-list">
			{
				items.map((item, index) => (
					<details class="faq-item" open={index === 0}>
						<summary>{item.question}</summary>
						<div class="faq-answer">
							<p>{item.answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>

<script is:inline>
	const faqSections = document.querySelectorAll('.service-faq');

	faqSections.forEach((section) => {
		const items = section.querySelectorAll('.faq-item');
		items.forEach((item) => {
			item.addEventListener('toggle', () => {
				if (!item.open) return;
				items.forEach((other) => {
					if (other !== item) other.open = false;
				});
			});
		});
	});
</script>

<style>
	.service-faq {
		background:
			linear-gradient(145deg, rgba(0, 0, 254, 0.98), rgba(0, 0, 220, 0.98)),
			url('/images/uk-dots-map.png');
		background-repeat: no-repeat;
		background-position: center;
		background-size: cover;
		color: var(--white);
	}

	.faq-inner {
		max-width: 760px;
	}

	.section-kicker {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font: 600 0.82rem/1 'League Spartan', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: rgba(255, 255, 255, 0.95);
	}

	.section-title {
		margin-top: 0.85rem;
		color: var(--white);
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.faq-list {
		margin-top: 1.35rem;
		display: grid;
		gap: 0.28rem;
	}

	.faq-item {
		margin: 0;
		background: rgba(255, 255, 255, 0.97);
		border-left: 4px solid var(--blue);
		color: var(--charcoal-100);
	}

	.faq-item summary {
		list-style: none;
		position: relative;
		cursor: pointer;
		padding: 0.78rem 2.2rem 0.78rem 0.72rem;
		font: 600 1rem/1.3 'League Spartan', Arial, sans-serif;
		color: #1f2460;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item summary::after {
		content: '+';
		position: absolute;
		right: 0.8rem;
		top: 50%;
		transform: translateY(-50%);
		font: 700 1.35rem/1 'League Spartan', Arial, sans-serif;
		color: #2430ad;
	}

	.faq-item[open] summary::after {
		content: '-';
	}

	.faq-answer {
		padding: 0 0.72rem 0.78rem;
	}

	.faq-answer p {
		color: var(--charcoal-300);
		font-size: 0.98rem;
		line-height: 1.7;
	}
</style>
