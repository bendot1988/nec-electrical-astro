---
import type { ServiceCardItem } from '../data/home';

interface Props {
	service: ServiceCardItem;
}

const { service } = Astro.props;
---

<article class="service-card brand-line-box" data-service-card data-category={service.category}>
	<img src={service.image} alt={service.title} loading="lazy" width="600" height="400" />
	<div class="service-body">
		<h3>{service.title}</h3>
		<p>{service.description}</p>
		<ul>
			{service.points.map((point) => <li>{point}</li>)}
		</ul>
		{
			service.href && (
				<a class="service-inline-link" href={service.href} aria-label={`View ${service.title} service page`}>
					View {service.title} <span aria-hidden="true">→</span>
				</a>
			)
		}
	</div>
</article>

<style>
	.service-card {
		position: relative;
		background: var(--white);
		clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
		box-shadow: 0 10px 30px rgba(20, 24, 38, 0.08);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.service-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 18px 36px rgba(20, 24, 38, 0.15);
	}

	.service-card img {
		width: 100%;
		height: clamp(170px, 18vw, 235px);
		object-fit: cover;
		object-position: center;
	}

	.service-body {
		padding: 1.05rem;
	}

	h3 {
		font-size: 1.35rem;
	}

	p {
		margin-top: 0.4rem;
		font-size: 0.95rem;
		color: var(--charcoal-400);
	}

	ul {
		margin: 0.8rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.45rem;
	}

	li {
		display: flex;
		align-items: flex-start;
		gap: 0.45rem;
		font-size: 0.88rem;
		line-height: 1.4;
	}

	li::before {
		content: '';
		width: 0.58rem;
		height: 0.58rem;
		border-radius: 50%;
		background: var(--blue);
		margin-top: 0.26rem;
		flex-shrink: 0;
	}

	.service-inline-link {
		margin-top: 1.25rem;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.5rem 0.8rem;
		font: 600 0.92rem/1 'League Spartan', Arial, sans-serif;
		letter-spacing: 0.01em;
		color: var(--blue);
		background: rgba(0, 0, 254, 0.06);
		clip-path: polygon(0 0, calc(100% - 9px) 0, 100% 9px, 100% 100%, 0 100%);
		transition: color 0.2s var(--motion-ease), background-color 0.2s var(--motion-ease), transform 0.2s
			var(--motion-ease);
	}

	.service-inline-link:hover {
		color: var(--white);
		background: var(--blue);
		transform: translateX(2px);
	}
</style>
