---
import type { InfoCardItem } from '../data/home';

interface Props {
	items: InfoCardItem[];
}

const { items } = Astro.props;
---

<section id="about" class="section">
	<div class="container">
		<h2 class="section-title">Why Choose NEC Ltd?</h2>
		<div class="card-grid">
			{
				items.map((item) => (
					<article class="info-card">
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.card-grid {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.2rem;
	}

	.info-card {
		background: var(--white);
		border: 1px solid #eceef5;
		border-radius: 0.85rem;
		padding: 1.25rem;
		box-shadow: 0 10px 26px rgba(21, 27, 44, 0.05);
	}

	h3 {
		font-size: 1.45rem;
		line-height: 1.08;
		letter-spacing: -0.02em;
	}

	p {
		margin-top: 0.8rem;
		color: var(--charcoal-400);
		font-size: 0.95rem;
		line-height: 1.75;
	}

	@media (max-width: 900px) {
		.card-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
