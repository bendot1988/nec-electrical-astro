---
import type { InfoCardItem } from '../data/home';

interface Props {
	items: InfoCardItem[];
}

const { items } = Astro.props;
---

<section id="about" class="section">
	<div class="container">
		<p class="bg-heading" aria-hidden="true">Why Choose NEC Ltd?</p>
		<h2 class="section-title">Why Choose NEC Ltd?</h2>
		<div class="card-grid">
			{
				items.map((item, index) => (
					<article class="info-card brand-line-box">
						<h3>{item.title}</h3>
						<div class="card-icon" aria-hidden="true">
							{
								index === 0 && (
									<svg viewBox="0 0 24 24" width="42" height="42" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M9 18h6" />
										<path d="M10 22h4" />
										<path d="M12 2a7 7 0 0 0-4 12.75c.58.45 1 1.15 1 1.89V18h6v-1.36c0-.74.42-1.44 1-1.89A7 7 0 0 0 12 2Z" />
									</svg>
								)
							}
							{
								index === 1 && (
									<svg viewBox="0 0 24 24" width="42" height="42" fill="none" stroke="currentColor" stroke-width="1.8">
										<circle cx="12" cy="8" r="5" />
										<path d="m8.5 13.5-1 7L12 18l4.5 2.5-1-7" />
									</svg>
								)
							}
							{
								index === 2 && (
									<svg viewBox="0 0 24 24" width="42" height="42" fill="none" stroke="currentColor" stroke-width="1.8">
										<path d="M12 3 5 6v6c0 4.97 3.1 8.03 7 9 3.9-.97 7-4.03 7-9V6l-7-3Z" />
										<circle cx="12" cy="11" r="2.2" />
										<path d="M8.8 16c.65-1.4 1.78-2.2 3.2-2.2s2.55.8 3.2 2.2" />
									</svg>
								)
							}
						</div>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	section {
		position: relative;
		background: #f3f4f6;
	}

	.container {
		position: relative;
	}

	.bg-heading {
		position: absolute;
		left: 0;
		top: -0.55rem;
		margin: 0;
		font: 600 clamp(2.9rem, 8vw, 6.3rem) / 0.9 'League Spartan', Arial, sans-serif;
		letter-spacing: -0.03em;
		color: rgba(33, 33, 40, 0.06);
		pointer-events: none;
		white-space: nowrap;
	}

	.section-title {
		position: relative;
		z-index: 1;
	}

	.card-grid {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.2rem;
		position: relative;
		z-index: 1;
	}

	.info-card {
		background: var(--white);
		padding: 1.25rem;
		clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 22px, 100% 100%, 0 100%);
		box-shadow: 0 10px 26px rgba(21, 27, 44, 0.05);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.info-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 18px 34px rgba(21, 27, 44, 0.14);
	}

	h3 {
		font-size: 1.45rem;
		line-height: 1.08;
		letter-spacing: -0.02em;
	}

	.card-icon {
		margin-top: 0.7rem;
		color: var(--blue);
		line-height: 0;
	}

	p {
		margin-top: 0.8rem;
		color: var(--charcoal-400);
		font-size: 0.95rem;
		line-height: 1.75;
	}

	@media (max-width: 900px) {
		.bg-heading {
			font-size: clamp(2.25rem, 12vw, 4rem);
			top: -0.3rem;
		}

		.card-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
