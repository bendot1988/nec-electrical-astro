---
import type { InfoCardItem } from '../data/home';

interface Props {
	items: InfoCardItem[];
}

const { items } = Astro.props;
---

<section id="safety" class="section">
	<div class="container">
		<p class="section-kicker">Compliance, Quality, and Safety</p>
		<h2 class="section-title">Accreditations</h2>
		<div class="card-grid">
			{
				items.map((item) => (
					<article class="info-card brand-line-box">
						{
							item.image && (
								<div class="badge-image-wrap">
									<img src={item.image} alt={item.title} loading="lazy" width="96" height="96" class="badge-image" />
								</div>
							)
						}
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.section-kicker {
		font: 600 0.73rem/1 'Open Sans', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--blue);
	}

	.card-grid {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.2rem;
	}

	.info-card {
		background: #f3f5fa;
		padding: 1.25rem;
		clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
		box-shadow: 0 10px 26px rgba(21, 27, 44, 0.05);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.info-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 18px 34px rgba(21, 27, 44, 0.14);
	}

	.badge-image-wrap {
		display: inline-flex;
		background: #e9edf7;
		border-radius: 0;
		padding: 0.5rem;
	}

	h3 {
		margin-top: 0.9rem;
		font-size: 1.45rem;
		line-height: 1.08;
		letter-spacing: -0.02em;
	}

	p {
		margin-top: 0.8rem;
		color: var(--charcoal-400);
		font-size: 0.95rem;
		line-height: 1.75;
	}

	@media (max-width: 900px) {
		.card-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
