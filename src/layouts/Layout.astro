---
interface Props {
	title: string;
	description: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
}

const { title, description, canonical, ogImage = '/images/hero-1.jpg', noindex = false } = Astro.props;
const canonicalUrl =
	canonical ??
	new URL(Astro.url.pathname, Astro.site ?? `${Astro.url.protocol}//${Astro.url.host}`).toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? `${Astro.url.protocol}//${Astro.url.host}`).toString();
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&family=Open+Sans:wght@400;600&display=swap"
		/>
		<title>{title}</title>

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:locale" content="en_GB" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<slot name="head" />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--charcoal-100: #212128;
		--charcoal-200: #333333;
		--charcoal-300: #444444;
		--charcoal-400: #6e7a84;
		--charcoal-500: #444444;
		--ghost-white: #f8f9fc;
		--white: #ffffff;
		--blue: #0000fe;
		--page-max: 1200px;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Open Sans', Arial, sans-serif;
		color: var(--charcoal-300);
		background: var(--white);
		line-height: 1.65;
	}

	h1,
	h2,
	h3,
	h4,
	h5,
	h6 {
		margin: 0;
		font-family: 'League Spartan', Arial, sans-serif;
		font-weight: 400;
		color: var(--charcoal-100);
	}

	p {
		margin: 0;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		max-width: 100%;
		display: block;
	}

	.container {
		width: min(100% - 2rem, var(--page-max));
		margin-inline: auto;
	}

	.section {
		padding: 5rem 0;
	}

	.section-title {
		font-size: clamp(2rem, 3vw, 2.5rem);
		line-height: 1.15;
		letter-spacing: -0.04em;
	}

	.section-subtitle {
		margin-top: 1rem;
		max-width: 65ch;
		color: var(--charcoal-400);
		font-size: 1rem;
		line-height: 1.9;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		border: 1px solid transparent;
		padding: 0.9rem 1.35rem;
		border-radius: 0;
		font: 600 1rem/1 'League Spartan', Arial, sans-serif;
		letter-spacing: 0.01em;
		transition: all 0.2s ease;
		cursor: pointer;
	}

	.btn-primary {
		background: var(--blue);
		color: var(--white);
	}

	.btn-primary:hover {
		filter: brightness(1.08);
	}

	.btn-outline {
		border-color: rgba(255, 255, 255, 0.45);
		color: var(--white);
		background: transparent;
	}

	.btn-outline:hover {
		border-color: var(--white);
		background: rgba(255, 255, 255, 0.12);
	}

	.brand-line-box {
		position: relative;
	}

	.brand-line-box::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		width: 100%;
		height: 5px;
		background: var(--blue);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.28s ease;
	}

	.brand-line-box:hover::after {
		transform: scaleX(1);
	}

	.skip-link {
		position: absolute;
		left: -1000px;
		top: auto;
	}

	.skip-link:focus {
		left: 1rem;
		top: 1rem;
		background: var(--white);
		color: var(--charcoal-100);
		padding: 0.5rem 0.85rem;
		border-radius: 0;
		z-index: 1000;
	}
</style>
