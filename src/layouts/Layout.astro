---
interface Props {
	title: string;
	description: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
}

const { title, description, canonical, ogImage = '/images/hero-1.jpg', noindex = false } = Astro.props;
const canonicalUrl =
	canonical ??
	new URL(Astro.url.pathname, Astro.site ?? `${Astro.url.protocol}//${Astro.url.host}`).toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? `${Astro.url.protocol}//${Astro.url.host}`).toString();
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&family=Open+Sans:wght@400;600&display=swap"
		/>
		<title>{title}</title>

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:locale" content="en_GB" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<slot name="head" />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<slot />
		<script is:inline>
			const MOTION_SELECTORS = [
				'.section .section-kicker',
				'.section .section-title',
				'.section .section-subtitle',
				'.service-card',
				'.info-card',
				'.news-card',
				'.contact-form',
				'.footer-col',
			];

			const applyDefaultMotionTargets = () => {
				for (const selector of MOTION_SELECTORS) {
					const nodes = document.querySelectorAll(selector);
					nodes.forEach((node) => {
						if (!node.hasAttribute('data-animate')) {
							node.setAttribute('data-animate', 'fade-up');
						}
					});
				}
			};

			const applyStaggerDelays = () => {
				const staggerParents = document.querySelectorAll('[data-animate-stagger]');
				staggerParents.forEach((parent) => {
					const step = Number.parseFloat(parent.getAttribute('data-animate-stagger') ?? '0.08');
					const children = parent.querySelectorAll(':scope > [data-animate]');
					children.forEach((child, index) => {
						if (!child.hasAttribute('data-animate-delay')) {
							child.setAttribute('data-animate-delay', `${index * step}`);
						}
					});
				});
			};

			const revealNode = (node) => {
				const delay = Number.parseFloat(node.getAttribute('data-animate-delay') ?? '0');
				if (Number.isFinite(delay) && delay > 0) {
					node.style.transitionDelay = `${delay}s`;
				}
				node.classList.add('is-visible');
			};

			const setupMotion = () => {
				applyDefaultMotionTargets();
				applyStaggerDelays();

				const animatedNodes = document.querySelectorAll('[data-animate]');
				if (!('IntersectionObserver' in window)) {
					animatedNodes.forEach((node) => revealNode(node));
					return;
				}

				const observer = new IntersectionObserver(
					(entries, instance) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							revealNode(entry.target);
							instance.unobserve(entry.target);
						});
					},
					{ threshold: 0.12, rootMargin: '0px 0px -6% 0px' },
				);

				animatedNodes.forEach((node) => {
					if (node.classList.contains('is-visible')) return;
					observer.observe(node);
				});
			};

			const bootMotion = () => {
				if (document.body?.dataset.motionBooted === 'true') return;
				document.body.dataset.motionBooted = 'true';
				document.documentElement.classList.add('motion-ready');
				setupMotion();
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', bootMotion, { once: true });
			} else {
				bootMotion();
			}
			document.addEventListener('astro:page-load', setupMotion);
			window.addEventListener('pageshow', setupMotion);
		</script>
	</body>
</html>

<style is:global>
	:root {
		--charcoal-100: #212128;
		--charcoal-200: #333333;
		--charcoal-300: #444444;
		--charcoal-400: #6e7a84;
		--charcoal-500: #444444;
		--ghost-white: #f8f9fc;
		--white: #ffffff;
		--blue: #0000fe;
		--page-max: 1200px;
		--motion-ease: cubic-bezier(0.22, 1, 0.36, 1);
		--motion-duration: 0.72s;
		--motion-distance: 26px;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Open Sans', Arial, sans-serif;
		color: var(--charcoal-300);
		background: var(--white);
		line-height: 1.65;
	}

	h1,
	h2,
	h3,
	h4,
	h5,
	h6 {
		margin: 0;
		font-family: 'League Spartan', Arial, sans-serif;
		font-weight: 400;
		color: var(--charcoal-100);
	}

	p {
		margin: 0;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		max-width: 100%;
		display: block;
	}

	.container {
		width: min(100% - 10%, var(--page-max));
		margin-inline: auto;
	}

	.section {
		padding: 5rem 0;
	}

	.section-title {
		font-size: clamp(2rem, 3vw, 2.5rem);
		line-height: 1.15;
		letter-spacing: -0.04em;
	}

	.section-subtitle {
		margin-top: 1rem;
		max-width: 65ch;
		color: var(--charcoal-400);
		font-size: 1rem;
		line-height: 1.9;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		border: 1px solid transparent;
		padding: 0.9rem 1.35rem;
		border-radius: 0;
		font: 600 1rem/1 'League Spartan', Arial, sans-serif;
		letter-spacing: 0.01em;
		transition: transform 0.22s var(--motion-ease), filter 0.22s var(--motion-ease), background-color 0.22s
			var(--motion-ease), border-color 0.22s var(--motion-ease), color 0.22s var(--motion-ease);
		cursor: pointer;
	}

	.btn-primary {
		background: var(--blue);
		color: var(--white);
	}

	.btn-primary:hover {
		transform: translateY(-1px);
		filter: brightness(1.08);
	}

	.btn-outline {
		border-color: rgba(255, 255, 255, 0.45);
		color: var(--white);
		background: transparent;
	}

	.btn-outline:hover {
		transform: translateY(-1px);
		border-color: var(--white);
		background: rgba(255, 255, 255, 0.12);
	}

	[data-animate] {
		opacity: 1;
		transform: none;
	}

	.motion-ready [data-animate] {
		opacity: 0;
		transform: translate3d(0, var(--motion-distance), 0);
		transition: opacity var(--motion-duration) var(--motion-ease), transform var(--motion-duration)
			var(--motion-ease);
		will-change: opacity, transform;
	}

	.motion-ready [data-animate='fade-left'] {
		transform: translate3d(calc(var(--motion-distance) * -1), 0, 0);
	}

	.motion-ready [data-animate='fade-right'] {
		transform: translate3d(var(--motion-distance), 0, 0);
	}

	.motion-ready [data-animate='zoom-in'] {
		transform: scale(0.95);
	}

	.motion-ready [data-animate].is-visible {
		opacity: 1;
		transform: none;
	}

	@media (prefers-reduced-motion: reduce) {
		html,
		body {
			scroll-behavior: auto;
		}
	}

	.brand-line-box {
		position: relative;
	}

	.brand-line-box::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		width: 100%;
		height: 5px;
		background: var(--blue);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.28s ease;
	}

	.brand-line-box:hover::after {
		transform: scaleX(1);
	}

	.skip-link {
		position: absolute;
		left: -1000px;
		top: auto;
	}

	.skip-link:focus {
		left: 1rem;
		top: 1rem;
		background: var(--white);
		color: var(--charcoal-100);
		padding: 0.5rem 0.85rem;
		border-radius: 0;
		z-index: 1000;
	}
</style>
