---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { navLinks } from '../../data/home';
import { projects } from '../../data/projects';
import { withBaseUrl } from '../../utils/withBaseUrl';

const project = projects.find((p) => p.slug === 'loades-unit-f')!;

const homeAnchors = navLinks.map((link) => ({
	...link,
	href: link.href.startsWith('/') ? link.href : `/${link.href}`,
}));

/** Vite emits hashed URLs — drop files here with the same basename as in `projects.ts` (e.g. `01-site-tour.mp4`). */
const loadesAssetUrls: Record<string, string> = {};
const loadesAssetGlob = import.meta.glob<{ default: string }>(
	'../../assets/projects/loades-unit-f/*.{mp4,mov,webm}',
	{ eager: true, import: 'url' }
);
for (const [key, mod] of Object.entries(loadesAssetGlob)) {
	const name = key.split('/').pop();
	if (name) loadesAssetUrls[name.toLowerCase()] = mod.default;
}

function resolveLoadesVideoSrc(storedPath: string): string {
	const filename = storedPath.split('/').pop()?.toLowerCase();
	if (filename && loadesAssetUrls[filename]) return loadesAssetUrls[filename];
	return withBaseUrl(storedPath);
}

function videoMimeTypeForPath(path: string): string {
	const tail = path.split('?')[0].toLowerCase();
	if (tail.endsWith('.webm')) return 'video/webm';
	if (tail.endsWith('.mov')) return 'video/quicktime';
	return 'video/mp4';
}

const posterUrl = withBaseUrl(project.heroImage);
const videoEntries =
	project.videos?.map((v) => ({
		...v,
		resolvedSrc: resolveLoadesVideoSrc(v.src),
		mimeType: videoMimeTypeForPath(v.src),
	})) ?? [];

const iconMap: Record<string, string> = {
	light: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 1 7 7c0 2.6-1.4 4.9-3.5 6.2V17H8.5v-1.8A7 7 0 0 1 5 9a7 7 0 0 1 7-7Z"/></svg>`,
	fire: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3c2 3 4 4.8 4 8.2a4 4 0 1 1-8 0c0-1.9.6-3.4 2.2-5.1"/><path d="M12 10c1.2 1.5 2 2.3 2 3.8a2 2 0 1 1-4 0c0-.9.3-1.6 1.1-2.4"/></svg>`,
	power: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.4 6.6a9 9 0 1 1-12.77.04"/><path d="M12 2v8"/></svg>`,
	cable: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="2" rx="1"/><circle cx="7" cy="12" r="2"/><circle cx="17" cy="12" r="2"/><path d="M7 10V7a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v3"/><path d="M7 14v3a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-3"/></svg>`,
};

const heroBgStyle = `background-image: url('${posterUrl}'); background-position: center 42%; background-size: cover; background-repeat: no-repeat;`;
---

<Layout
	title={`${project.title} | Projects | NEC Ltd Electrical`}
	description={project.excerpt}
	canonical={`https://dotwall.dev/nec${project.href}`}
	ogImage={project.heroImage}
>
	<Header links={homeAnchors} ctaHref="/#contact" />

	<main id="main-content">
		<section class="project-hero">
			<div class="project-hero-bg" style={heroBgStyle} aria-hidden="true"></div>
			<div class="project-hero-overlay" aria-hidden="true"></div>
			<div class="container project-hero-content">
				<nav class="crumbs" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span aria-hidden="true">›</span>
					<a href="/projects/">Projects</a>
					<span aria-hidden="true">›</span>
					<span aria-current="page">{project.title}</span>
				</nav>
				<div class="hero-tags">
					{project.tags.map((tag) => <span class="hero-tag">{tag}</span>)}
				</div>
				<h1>{project.title}</h1>
				<p class="hero-subtitle">{project.subtitle}</p>
			</div>
		</section>

		<div class="stats-strip">
			<div class="container stats-inner">
				<div class="stat-item">
					<span class="stat-label">Sector</span>
					<span class="stat-value">{project.sector}</span>
				</div>
				<div class="stat-divider" aria-hidden="true"></div>
				<div class="stat-item">
					<span class="stat-label">Package</span>
					<span class="stat-value">{project.value}</span>
				</div>
				<div class="stat-divider" aria-hidden="true"></div>
				<div class="stat-item">
					<span class="stat-label">Programme</span>
					<span class="stat-value">{project.duration}</span>
				</div>
				<div class="stat-divider" aria-hidden="true"></div>
				<div class="stat-item">
					<span class="stat-label">Location</span>
					<span class="stat-value">{project.location}</span>
				</div>
			</div>
		</div>

		<section class="section project-overview">
			<div class="container overview-grid" data-animate="fade-up">
				<div class="overview-copy">
					<p class="section-kicker">
						<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
							<path
								fill="currentColor"
								d="M13.2 2.8c.2-.5-.5-.9-.8-.4L6.7 12.1a.5.5 0 0 0 .4.8h3.1L9.5 21c-.1.6.6.9.9.4l6.8-10.7a.5.5 0 0 0-.4-.8h-3.4l-.2-7.1Z"
							></path>
						</svg>
						Project Overview
					</p>
					<h2 class="section-title">From Empty Shell to Energisation-Ready.</h2>
					<p>
						Unit F reads like a blank canvas: high-bay volume, honest structure, and long sightlines
						across a floor plate that will one day hum with activity. Our job was to turn that openness
						into order — containment that runs like motorways, circuits grouped with discipline, and an
						LV front end that tells the commissioning story before a single breaker is closed.
					</p>
					<p>
						The photography here is deliberately quiet: white-lined walls, cable tray stacked in logical
						tiers, and a Schneider Electric assembly presented the way we like to hand over — labelled,
						accessible, and ready for the client&apos;s O&amp;M pack. It is the kind of installation you
						can walk a visitor through without apologising for a single corner.
					</p>
					<p>
						When the shell is as crisp as Unit F, the electrical installation has nowhere to hide. We use
						that as a benchmark: every tray run and every gland plate should read as intentional, so the
						space is ready for whatever fit-out follows — without rework on the backbone we have already
						installed.
					</p>
				</div>
				<figure class="overview-image brand-line-box" data-animate="fade-up">
					<img
						src="/images/projects/loades-unit-f/lv-distribution.png"
						alt="Loades Unit F — LV distribution boards and trunking on a finished industrial wall"
						loading="lazy"
						width="1600"
						height="900"
					/>
				</figure>
			</div>
		</section>

		<section class="section scope-section">
			<div class="container">
				<p class="section-kicker">
					<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
						<path
							fill="currentColor"
							d="M13.2 2.8c.2-.5-.5-.9-.8-.4L6.7 12.1a.5.5 0 0 0 .4.8h3.1L9.5 21c-.1.6.6.9.9.4l6.8-10.7a.5.5 0 0 0-.4-.8h-3.4l-.2-7.1Z"
						></path>
					</svg>
					Scope of Works
				</p>
				<h2 class="section-title">What We Delivered</h2>
				<p class="section-subtitle">
					Industrial electrical delivery focused on containment, distribution, and a commissioning-ready
					finish.
				</p>

				<div class="scope-grid" data-animate-stagger="0.07">
					{
						project.scope.map((item) => (
							<article class="scope-card brand-line-box" data-animate="fade-up">
								<div class="icon-wrap" aria-hidden="true" set:html={iconMap[item.icon] ?? iconMap.power} />
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section gallery-section">
			<div class="container">
				<p class="section-kicker">
					<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
						<path
							fill="currentColor"
							d="M13.2 2.8c.2-.5-.5-.9-.8-.4L6.7 12.1a.5.5 0 0 0 .4.8h3.1L9.5 21c-.1.6.6.9.9.4l6.8-10.7a.5.5 0 0 0-.4-.8h-3.4l-.2-7.1Z"
						></path>
					</svg>
					Site Photography
				</p>
				<h2 class="section-title">Project Gallery</h2>

				<div class="gallery-grid" data-animate-stagger="0.05">
					{
						project.galleryImages.map((img, i) => (
							<figure class={`gallery-tile brand-line-box ${i === 0 ? 'tile-wide' : ''}`} data-animate="fade-up">
								<img src={img.src} alt={img.alt} loading="lazy" width="1600" height="900" />
							</figure>
						))
					}
				</div>
			</div>
		</section>

		{
			videoEntries.length > 0 && (
				<section class="section video-section">
					<div class="container">
						<p class="section-kicker">
							<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
								<path
									fill="currentColor"
									d="M13.2 2.8c.2-.5-.5-.9-.8-.4L6.7 12.1a.5.5 0 0 0 .4.8h3.1L9.5 21c-.1.6.6.9.9.4l6.8-10.7a.5.5 0 0 0-.4-.8h-3.4l-.2-7.1Z"
								></path>
							</svg>
							On-site film
						</p>
						<h2 class="section-title">Walk the Unit</h2>
						<p class="section-subtitle">
							Two short films from site: trunking and containment in the warehouse, then LV distribution in
							the office area ahead of handover.
						</p>

						<div class="video-grid" data-animate-stagger="0.08">
							{videoEntries.map((v) => (
								<figure class="video-card brand-line-box" data-animate="fade-up">
									<div class="video-frame">
										<div class="video-story">
											<video controls playsinline preload="metadata" poster={posterUrl}>
												<source src={v.resolvedSrc} type={v.mimeType} />
											</video>
										</div>
									</div>
									<figcaption>
										<strong>{v.title}</strong>
										{v.caption && <span class="video-caption">{v.caption}</span>}
										<a href={v.resolvedSrc} class="video-download">Download clip</a>
									</figcaption>
								</figure>
							))}
						</div>
					</div>
				</section>
			)
		}

		<section class="section narrative-section">
			<div class="container narrative-grid">
				<div class="narrative-images" data-animate-stagger="0.07">
					<figure class="media-tile brand-line-box" data-animate="fade-up">
						<img
							src="/images/projects/loades-unit-f/warehouse-interior.png"
							alt="Loades Unit F — long internal elevation with containment and structural columns"
							loading="lazy"
							width="1600"
							height="900"
						/>
					</figure>
					<figure class="media-tile brand-line-box" data-animate="fade-up">
						<img
							src="/images/projects/loades-unit-f/lv-distribution.png"
							alt="Loades Unit F — Schneider LV equipment and trunking"
							loading="lazy"
							width="1600"
							height="900"
						/>
					</figure>
				</div>
				<div class="narrative-copy" data-animate="fade-up">
					<h2 class="section-title">Why This Matters on Handover.</h2>
					<p>
						Industrial tenants rarely fall in love with a distribution board — until something trips at
						17:00 on a Friday. The work shown here is about shrinking that risk: consistent containment,
						straightforward access, and equipment staged so testing and witness inspections move quickly.
					</p>
					<p>
						When the shell is as crisp as Unit F, the electrical installation has nowhere to hide. We treat
						that as an advantage: every tray run and every gland plate becomes part of the quality signal
						you send to the client before they sign the completion paperwork.
					</p>
				</div>
			</div>
		</section>

		<section class="section cta-band">
			<div class="container cta-inner" data-animate="fade-up">
				<div class="cta-copy">
					<h2>Industrial unit coming on stream?</h2>
					<p>Talk to NEC about design-and-build electrical delivery for warehousing and commercial shells.</p>
				</div>
				<div class="cta-actions">
					<a href="/#contact" class="btn btn-primary">Get in touch</a>
					<a href="/projects/" class="btn btn-outline btn-outline-white">All projects</a>
				</div>
			</div>
		</section>
	</main>

	<Footer links={homeAnchors} />
</Layout>

<style>
	.project-hero {
		position: relative;
		min-height: clamp(320px, 50vw, 480px);
		display: grid;
		align-items: end;
		overflow: clip;
	}
	.project-hero-bg,
	.project-hero-overlay {
		position: absolute;
		inset: 0;
	}
	.project-hero-overlay {
		background: linear-gradient(115deg, rgba(10, 18, 42, 0.78), rgba(10, 18, 42, 0.35));
	}
	.project-hero-content {
		position: relative;
		z-index: 1;
		color: var(--white);
		padding-bottom: clamp(1.6rem, 3.5vw, 3rem);
	}
	.crumbs {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.42rem;
		font: 400 0.88rem/1.2 'League Spartan', Arial, sans-serif;
	}
	.crumbs a {
		color: rgba(255, 255, 255, 0.82);
	}
	.hero-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: 1.1rem;
	}
	.hero-tag {
		display: inline-block;
		font: 600 0.75rem/1 'League Spartan', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: rgba(255, 255, 255, 0.9);
		background: rgba(255, 255, 255, 0.14);
		border: 1px solid rgba(255, 255, 255, 0.22);
		padding: 0.32rem 0.7rem;
		border-radius: 2px;
	}
	h1 {
		margin-top: 0.9rem;
		font-size: clamp(2.2rem, 7vw, 4.4rem);
		letter-spacing: -0.03em;
		line-height: 0.97;
		color: var(--white);
		max-width: 16ch;
	}
	.hero-subtitle {
		margin-top: 1rem;
		font-size: clamp(1rem, 1.5vw, 1.15rem);
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.78);
		max-width: 54ch;
	}
	.stats-strip {
		background: #0a122a;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.stats-inner {
		display: flex;
		align-items: stretch;
		flex-wrap: wrap;
		padding-top: 0;
		padding-bottom: 0;
	}
	.stat-item {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		padding: 1.4rem 0;
		flex: 1;
		min-width: 140px;
	}
	.stat-divider {
		width: 1px;
		background: rgba(255, 255, 255, 0.1);
		margin: 1rem 2rem;
		flex-shrink: 0;
	}
	.stat-label {
		font: 600 0.74rem/1 'League Spartan', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: rgba(255, 255, 255, 0.5);
	}
	.stat-value {
		font: 700 1.05rem/1.2 'League Spartan', Arial, sans-serif;
		color: var(--white);
	}
	.project-overview {
		background: var(--white);
	}
	.overview-grid {
		display: grid;
		grid-template-columns: 1fr 420px;
		gap: 4rem;
		align-items: start;
	}
	.section-kicker {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font: 600 0.86rem/1 'League Spartan', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--blue);
	}
	.section-subtitle {
		margin-top: 0.75rem;
		font-size: 1.05rem;
		line-height: 1.65;
		color: var(--charcoal-400);
		max-width: 62ch;
	}
	.overview-copy p {
		margin-top: 1.1rem;
		font-size: 1rem;
		line-height: 1.78;
		color: var(--charcoal-400);
		max-width: 62ch;
	}
	.overview-image {
		margin: 0;
		clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 22px, 100% 100%, 0 100%);
		overflow: clip;
		background: #e8edf8;
	}
	.overview-image img {
		width: 100%;
		display: block;
		height: 420px;
		object-fit: cover;
		object-position: center;
	}
	.scope-section {
		background: var(--ghost-white);
	}
	.scope-grid {
		margin-top: 2.5rem;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.95rem;
	}
	.scope-card {
		position: relative;
		background: #ffffff;
		clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
		padding: 1.35rem 1.35rem 1.5rem;
		box-shadow: 0 10px 26px rgba(21, 27, 44, 0.06);
	}
	.icon-wrap {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.35rem;
		height: 3.35rem;
		border-radius: 50%;
		color: var(--white);
		background: linear-gradient(145deg, #2a34ff, #0000fe);
	}
	.scope-card h3 {
		margin-top: 1.1rem;
		padding-top: 0.9rem;
		border-top: 1px solid rgba(0, 0, 254, 0.2);
		font-size: clamp(1.35rem, 1.8vw, 1.75rem);
		line-height: 1.1;
	}
	.scope-card p {
		margin-top: 0.85rem;
		font-size: 0.96rem;
		line-height: 1.72;
		color: var(--charcoal-400);
	}
	.gallery-section {
		background: var(--white);
	}
	.gallery-grid {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-auto-rows: 240px;
		gap: 0.8rem;
	}
	.gallery-tile {
		margin: 0;
		clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 0 100%);
		overflow: clip;
		background: #dde3f0;
	}
	.gallery-tile.tile-wide {
		grid-column: span 2;
		grid-row: span 2;
	}
	.gallery-tile img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.video-section {
		background: var(--ghost-white);
	}
	.video-grid {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}
	.video-card {
		margin: 0;
		clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
		overflow: clip;
		background: #0a122a;
	}
	.video-frame {
		position: relative;
		aspect-ratio: 16 / 9;
		min-height: clamp(200px, 36vw, 420px);
		background: linear-gradient(180deg, #0a122a 0%, #050a18 100%);
		overflow: hidden;
	}
	/* Instagram story ratio (9×16 portrait), centred inside the 16×9 player chrome */
	.video-story {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.video-story video {
		height: 100%;
		width: auto;
		max-width: 100%;
		max-height: 100%;
		aspect-ratio: 9 / 16;
		display: block;
		object-fit: contain;
		background: #000;
	}
	.video-card figcaption {
		padding: 1rem 1.15rem 1.2rem;
		background: #fff;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		font-size: 0.92rem;
		line-height: 1.5;
		color: var(--charcoal-400);
	}
	.video-card figcaption strong {
		font: 700 1.05rem/1.2 'League Spartan', Arial, sans-serif;
		color: #0a122a;
	}
	.video-caption {
		display: block;
	}
	.video-download {
		display: inline-block;
		margin-top: 0.35rem;
		font: 600 0.82rem/1.2 'League Spartan', Arial, sans-serif;
		color: var(--blue);
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.video-download:hover {
		text-decoration: none;
	}
	.narrative-section {
		background: var(--white);
	}
	.narrative-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3.5rem;
		align-items: start;
	}
	.narrative-images {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.media-tile {
		margin: 0;
		clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 0 100%);
		overflow: clip;
		background: #e8edf8;
	}
	.media-tile img {
		width: 100%;
		height: 300px;
		object-fit: cover;
		object-position: center;
		display: block;
	}
	.narrative-copy p {
		margin-top: 1.1rem;
		font-size: 1rem;
		line-height: 1.78;
		color: var(--charcoal-400);
	}
	.cta-band {
		background: linear-gradient(135deg, #0a122a 0%, #0d1b40 100%);
	}
	.cta-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.cta-copy h2 {
