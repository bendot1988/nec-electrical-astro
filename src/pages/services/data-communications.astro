---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceWhyChooseSection from '../../components/ServiceWhyChooseSection.astro';
import ServiceFaqSection from '../../components/ServiceFaqSection.astro';
import { navLinks } from '../../data/home';

const pageTitle = 'Data & Communications Services | NEC Ltd Electrical';
const pageDescription =
	'Specialist data and communications support from NEC Ltd Electrical, delivered as part of our complete design and build services.';
const homeAnchors = navLinks.map((link) => ({ ...link, href: link.href.startsWith('/') ? link.href : `/${link.href}` }));

const serviceHighlights = [
	{
		title: 'Full In-House Design Services',
		description:
			'Our team develops bespoke electrical schemes tailored to the specific demands of your facility. We coordinate closely with site managers and developers from the tender stage to ensure every requirement is met.',
		icon: 'idea',
	},
	{
		title: 'AutoCAD Drawings',
		description:
			'Precision is non-negotiable. We produce detailed AutoCAD layouts and schematics, providing a clear visual and technical roadmap for the entire installation process.',
		icon: 'draw',
	},
	{
		title: 'Testing & Commissioning',
		description:
			'Safety is our baseline. All systems undergo rigorous testing to ensure they meet BS 7671 standards and operate at peak performance before handover.',
		icon: 'check',
	},
	{
		title: 'O&M Documentation',
		description:
			'We provide comprehensive Operation and Maintenance manuals, ensuring your facilities management team has the data they need to maintain the building integrity long after we leave the site.',
		icon: 'docs',
	},
];

const whyChooseItems = [
	{
		number: '01',
		title: 'Seamless Coordination',
		description:
			'As a design-led team, we close the gap between technical planning and site delivery, reducing surprises and keeping projects on programme.',
	},
	{
		number: '02',
		title: 'Safety & Compliance',
		description:
			'With CHAS accreditation and qualified site supervision, every solution is designed and delivered around robust safety standards.',
	},
	{
		number: '03',
		title: 'Value Engineering',
		description:
			'Our in-house expertise helps identify practical savings during design without compromising quality, performance, or lifecycle value.',
	},
	{
		number: '04',
		title: 'Strategic Location',
		description:
			'Based in Kettering, we are well placed to support projects across the UK with responsive technical input when it matters.',
	},
];

const faqItems = [
	{
		question: 'Why is an NICEIC approved contractor important for design work?',
		answer:
			'NICEIC approval is an industry benchmark. It confirms our designs and installations are independently assessed for compliance, quality, and current UK regulations.',
	},
	{
		question: 'Do you handle full technical submittals for tenders?',
		answer:
			'Yes. We prepare complete technical submissions including design intent, schematics, specifications, and supporting documentation to help clients and consultants review quickly.',
	},
	{
		question: 'Can you integrate PV and LED controls into the design?',
		answer:
			'Absolutely. We design integrated electrical strategies that include PV systems, lighting control, and energy-efficient LED solutions tailored to each site.',
	},
];
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="https://dotwall.dev/nec/services/data-communications/"
	ogImage="/images/service-data-communications.jpeg"
>
	<Header links={homeAnchors} ctaHref="/#contact" />

	<main id="main-content">
		<section class="service-hero">
			<div class="service-hero-bg" aria-hidden="true"></div>
			<div class="service-hero-overlay" aria-hidden="true"></div>
			<div class="container service-hero-content">
				<nav class="crumbs" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span aria-hidden="true">›</span>
					<a href="/#services">Service</a>
					<span aria-hidden="true">›</span>
					<span aria-current="page">Data & Communications</span>
				</nav>
				<h1>Data & Communications</h1>
			</div>
		</section>

		<section class="section service-intro">
			<div class="container">
				<p class="section-kicker">
					<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
						<path
							fill="currentColor"
							d="M13.2 2.8c.2-.5-.5-.9-.8-.4L6.7 12.1a.5.5 0 0 0 .4.8h3.1L9.5 21c-.1.6.6.9.9.4l6.8-10.7a.5.5 0 0 0-.4-.8h-3.4l-.2-7.1Z"
						></path>
					</svg>
					What we provide
				</p>
				<h2 class="section-title">Our Comprehensive Design & Technical Services</h2>
				<p class="section-subtitle">
					We take the complexity out of electrical infrastructure by providing a full suite of in-house technical
					services. By integrating design and installation, we eliminate the friction often found between separate
					consultants and contractors.
				</p>

				<div class="highlight-grid" data-animate-stagger="0.07">
					{
						serviceHighlights.map((item) => (
							<article class="highlight-card brand-line-box" data-animate="fade-up">
								<div class="icon-wrap" aria-hidden="true">
									{
										item.icon === 'idea' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M9.5 18h5"></path>
												<path d="M10 22h4"></path>
												<path d="M12 2a7 7 0 0 0-4.4 12.5c.8.6 1.4 1.4 1.8 2.3h5.2c.4-.9 1-1.7 1.8-2.3A7 7 0 0 0 12 2Z"></path>
											</svg>
										)
									}
									{
										item.icon === 'draw' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<path d="m3 21 3.8-1 11-11a2.1 2.1 0 1 0-3-3l-11 11L3 21Z"></path>
												<path d="m13.5 6.5 3 3"></path>
											</svg>
										)
									}
									{
										item.icon === 'check' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<path d="m5 13 4 4L19 7"></path>
											</svg>
										)
									}
									{
										item.icon === 'docs' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<rect x="6" y="3" width="12" height="18" rx="2"></rect>
												<path d="M9 8h6"></path>
												<path d="M9 12h6"></path>
												<path d="M9 16h4"></path>
											</svg>
										)
									}
								</div>
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section partnership">
			<div class="container">
				<div class="partnership-top">
					<figure class="media-tile media-top-left brand-line-box" data-animate="fade-up">
						<img
							src="/images/service-design-partnership-top-left.png"
							alt="Electrical installation and cable infrastructure in a facility"
							loading="lazy"
							width="900"
							height="900"
						/>
					</figure>
					<figure class="media-tile media-top-right brand-line-box" data-animate="fade-up">
						<img
							src="/images/service-design-partnership-top-right.png"
							alt="Engineer reviewing technical plans on dual monitors"
							loading="lazy"
							width="900"
							height="900"
						/>
					</figure>
				</div>

				<div class="partnership-main">
					<figure class="media-tile media-tile-large media-bottom-left brand-line-box" data-animate="fade-left">
						<img
							src="/images/service-design-partnership-bottom-left.png"
							alt="Technical CAD design plans displayed on a desktop workstation"
							loading="lazy"
							width="900"
							height="900"
						/>
					</figure>

					<div class="partnership-copy" data-animate="fade-right">
						<h2 class="section-title">A Design-Led Partnership from Day One</h2>
						<p>
							From tender stage onward, we work as part of your team. With design and installation handled under one
							roof, projects move faster, stay aligned, and remain compliant at every step.
						</p>

						<ul>
							<li>In-house design and engineering support</li>
							<li>Clear AutoCAD drawings across all scopes</li>
							<li>Thorough BS 7671 testing and commissioning</li>
							<li>Complete O&amp;M documentation at handover</li>
							<li>NICEIC Approved - independently assessed</li>
							<li>CHAS Accredited - health and safety assured</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<ServiceWhyChooseSection
			title="Why Choose NEC Electrical for Your Design & Build?"
			description="Choosing a partner that manages both technical design and physical installation gives your project a clear commercial advantage at every stage."
			items={whyChooseItems}
		/>

		<ServiceFaqSection items={faqItems} />
	</main>

	<Footer links={homeAnchors} />
</Layout>

<style>
	.service-hero {
		position: relative;
		min-height: clamp(290px, 42vw, 380px);
		display: grid;
		align-items: end;
		overflow: clip;
	}

	.service-hero-bg,
	.service-hero-overlay {
		position: absolute;
		inset: 0;
	}

	.service-hero-bg {
		background: center / cover no-repeat url('/images/service-data-communications.jpeg');
	}

	.service-hero-overlay {
		background: linear-gradient(115deg, rgba(10, 18, 42, 0.82), rgba(10, 18, 42, 0.5));
	}

	.service-hero-content {
		position: relative;
		z-index: 1;
		color: var(--white);
		padding-bottom: clamp(1.4rem, 3vw, 2.5rem);
	}

	.crumbs {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.42rem;
		font: 400 0.88rem/1.2 'League Spartan', Arial, sans-serif;
	}

	.crumbs a {
		color: rgba(255, 255, 255, 0.86);
		transition: color 0.2s var(--motion-ease);
	}

	.crumbs a:hover {
		color: var(--white);
	}

	h1 {
		margin-top: 0.85rem;
		font-size: clamp(2.1rem, 6.8vw, 4.2rem);
		letter-spacing: -0.03em;
		line-height: 0.98;
		max-width: 8ch;
		color: var(--white);
	}

	.service-intro {
		background: var(--ghost-white);
	}

	.section-kicker {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font: 600 0.86rem/1 'League Spartan', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--blue);
	}

	.highlight-grid {
		margin-top: 2.5rem;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.95rem;
	}

	.highlight-card {
		position: relative;
		background: #ffffff;
		clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
		padding: 1.35rem 1.35rem 1.4rem;
		box-shadow: 0 10px 26px rgba(21, 27, 44, 0.06);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.highlight-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 18px 34px rgba(21, 27, 44, 0.14);
	}

	.icon-wrap {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.35rem;
		height: 3.35rem;
		border-radius: 50%;
		color: var(--white);
		background: linear-gradient(145deg, #2a34ff, #0000fe);
		transition: transform 0.25s ease;
	}

	.highlight-card:hover .icon-wrap {
		transform: translateY(-2px) scale(1.04);
	}

	.icon-wrap svg {
		width: 1.45rem;
		height: 1.45rem;
	}

	h3 {
		margin-top: 1.1rem;
		padding-top: 0.9rem;
		border-top: 1px solid rgba(0, 0, 254, 0.2);
		font-size: 2rem;
		font-size: clamp(1.45rem, 2vw, 2rem);
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.highlight-card p {
		margin-top: 0.85rem;
		font-size: 0.98rem;
		line-height: 1.72;
		color: var(--charcoal-400);
	}

	@media (max-width: 1060px) {
		.highlight-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.highlight-grid {
			grid-template-columns: 1fr;
		}
	}

	.partnership {
		background: var(--white);
	}

	.partnership-top {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.8rem;
	}

	.media-tile {
		margin: 0;
		clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 22px, 100% 100%, 0 100%);
		overflow: clip;
		background: #e8edf8;
	}

	.media-tile img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.media-top-left img {
		aspect-ratio: 1.25 / 1;
		object-position: center;
	}

	.media-top-right img {
		aspect-ratio: 1.25 / 1;
		object-position: center;
	}

	.partnership-main {
		margin-top: 2.2rem;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
		gap: 2rem;
		align-items: stretch;
	}

	.media-bottom-left img {
		aspect-ratio: 1.25 / 1;
		object-position: center;
	}

	.partnership-copy {
		background: var(--white);
		padding: 0.2rem 0;
		max-width: 36rem;
	}

	.partnership-copy .section-title {
		font-size: clamp(2.35rem, 4.4vw, 3.6rem);
		line-height: 1.05;
		max-width: 12ch;
	}

	.partnership-copy p {
		margin-top: 1.2rem;
		max-width: 50ch;
		font-size: 1.03rem;
		line-height: 1.72;
		color: var(--charcoal-400);
	}

	.partnership-copy ul {
		margin: 1.2rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.52rem;
	}

	.partnership-copy li {
		position: relative;
		padding-left: 1.72rem;
		font-size: 0.97rem;
		line-height: 1.42;
		color: var(--charcoal-300);
	}

	.partnership-copy li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.25rem;
		width: 1rem;
		height: 1rem;
		border-radius: 50%;
		background: var(--blue);
	}

	.partnership-copy li::after {
		content: '';
		position: absolute;
		left: 0.33rem;
		top: 0.53rem;
		width: 0.35rem;
		height: 0.2rem;
		border-left: 2px solid var(--white);
		border-bottom: 2px solid var(--white);
		transform: rotate(-45deg);
	}

	@media (max-width: 980px) {
		.partnership-main {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}

		.partnership-copy {
			padding: 0.2rem 0 0;
			max-width: 100%;
		}
	}

	@media (max-width: 700px) {
		.partnership-top {
			grid-template-columns: 1fr;
		}
	}
</style>
