---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceWhyChooseSection from '../../components/ServiceWhyChooseSection.astro';
import ServiceFaqSection from '../../components/ServiceFaqSection.astro';
import { navLinks } from '../../data/home';

const pageTitle = 'Security & Safety Services | NEC Ltd Electrical';
const pageDescription =
	'Integrated security and safety systems from NEC Ltd Electrical, including fire alarms, intruder alarms, CCTV, and access control.';
const homeAnchors = navLinks.map((link) => ({ ...link, href: link.href.startsWith('/') ? link.href : `/${link.href}` }));

const securityHighlights = [
	{
		title: 'Fire Alarm Systems',
		description:
			'Design, supply, and installation of BS 5839-compliant fire detection and alarm systems from conventional panels to fully addressable networked solutions.',
		icon: 'fire',
	},
	{
		title: 'Intruder Alarm Systems',
		description:
			'NSI/SSAIB-grade intruder alarm systems tailored to your site, with fully monitored and remote signalling options for commercial and industrial premises.',
		icon: 'shield',
	},
	{
		title: 'CCTV Systems',
		description:
			'HD IP and analogue CCTV systems with remote viewing capability. We design camera coverage to BS EN 62676 standards for clear, evidential-quality footage.',
		icon: 'camera',
	},
	{
		title: 'Access Control Systems',
		description:
			'From standalone keypad entry to multi-site biometric management systems, we supply and install robust access solutions to control movement throughout your facility.',
		icon: 'docs',
	},
];

const whyChooseItems = [
	{
		number: '01',
		title: 'Seamless Coordination',
		description:
			'As a design-led firm, we bridge the gap between architectural vision and electrical reality. This reduces on-site surprises and keeps the programme on track.',
	},
	{
		number: '02',
		title: 'Safety & Compliance',
		description:
			'With CHAS Accreditation and qualified site supervision, our technical designs are built around uncompromising Health & Safety standards.',
	},
	{
		number: '03',
		title: 'Value Engineering',
		description:
			'Our in-house expertise helps identify cost-saving opportunities during design without compromising quality, reliability, or lifecycle performance.',
	},
	{
		number: '04',
		title: 'Strategic Location',
		description:
			'Operating from Kettering, we are well placed to support projects across the UK with responsive technical support whenever required.',
	},
];

const faqItems = [
	{
		question: 'Do you design and install fire alarm systems to BS 5839?',
		answer:
			'Yes. All fire alarm installations are designed and commissioned to BS 5839-1 for commercial premises. We carry out site surveys, produce design drawings, and provide full handover documentation, including O&M manuals.',
	},
	{
		question: 'Can you integrate access control with an existing electrical installation?',
		answer:
			'Absolutely. Our engineers assess existing infrastructure to design systems that integrate cleanly by running dedicated cable routes, tying into door operators, or linking with building management systems.',
	},
	{
		question: 'Are your CCTV systems suitable for insurance compliance?',
		answer:
			'We design systems to BS EN 62676. This ensures camera placement, resolution, and storage meet most commercial insurer requirements. We can also provide documentation to support insurance applications.',
	},
	{
		question: 'Do you offer maintenance contracts for security systems?',
		answer:
			'Yes. We offer annual service and maintenance agreements covering fire alarm testing, intruder alarm servicing, and CCTV health checks to help you stay compliant year-round.',
	},
];
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="https://dotwall.dev/nec/services/security-safety/"
	ogImage="/images/service-security-hero.png"
>
	<Header links={homeAnchors} ctaHref="/#contact" />

	<main id="main-content">
		<section class="service-hero">
			<div class="service-hero-bg" aria-hidden="true"></div>
			<div class="service-hero-overlay" aria-hidden="true"></div>
			<div class="container service-hero-content">
				<nav class="crumbs" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span aria-hidden="true">›</span>
					<a href="/#services">Service</a>
					<span aria-hidden="true">›</span>
					<span aria-current="page">Security & Safety</span>
				</nav>
				<h1>Security & Safety</h1>
			</div>
		</section>

		<section class="section service-intro">
			<div class="container">
				<p class="section-kicker">
					<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
						<path
							fill="currentColor"
							d="M13.2 2.8c.2-.5-.5-.9-.8-.4L6.7 12.1a.5.5 0 0 0 .4.8h3.1L9.5 21c-.1.6.6.9.9.4l6.8-10.7a.5.5 0 0 0-.4-.8h-3.4l-.2-7.1Z"
						></path>
					</svg>
					What we provide
				</p>
				<h2 class="section-title">Comprehensive Security & Safety Services</h2>
				<p class="section-subtitle">
					We design and install fully compliant fire, intruder, and access systems that integrate seamlessly with
					your building&apos;s electrical infrastructure.
				</p>

				<div class="highlight-grid" data-animate-stagger="0.07">
					{
						securityHighlights.map((item) => (
							<article class="highlight-card brand-line-box" data-animate="fade-up">
								<div class="icon-wrap" aria-hidden="true">
									{
										item.icon === 'fire' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M12 3c2 3 4 4.8 4 8.2a4 4 0 1 1-8 0c0-1.9.6-3.4 2.2-5.1"></path>
												<path d="M12 10c1.2 1.5 2 2.3 2 3.8a2 2 0 1 1-4 0c0-.9.3-1.6 1.1-2.4"></path>
											</svg>
										)
									}
									{
										item.icon === 'shield' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M12 3 5 6v6c0 4.97 3.1 8.03 7 9 3.9-.97 7-4.03 7-9V6l-7-3Z"></path>
												<path d="m9.3 11.9 1.9 1.9 3.5-3.5"></path>
											</svg>
										)
									}
									{
										item.icon === 'camera' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M3 10.5V7.8A1.8 1.8 0 0 1 4.8 6h7.1"></path>
												<path d="M17 8.5 21 7v10l-4-1.5"></path>
												<rect x="3" y="9" width="14" height="8" rx="2"></rect>
											</svg>
										)
									}
									{
										item.icon === 'docs' && (
											<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
												<rect x="6" y="3" width="12" height="18" rx="2"></rect>
												<path d="M9 8h6"></path>
												<path d="M9 12h6"></path>
												<path d="M9 16h4"></path>
											</svg>
										)
									}
								</div>
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="section security-narrative">
			<div class="container">
				<div class="narrative-images" data-animate-stagger="0.07">
					<figure class="media-tile brand-line-box" data-animate="fade-up">
						<img
							src="/images/service-security-card-access-control.png"
							alt="Access control keypad installed in a modern corridor"
							loading="lazy"
							width="900"
							height="900"
						/>
					</figure>
					<figure class="media-tile brand-line-box" data-animate="fade-up">
						<img
							src="/images/service-security-card-fire-alarm.png"
							alt="Engineer commissioning a fire alarm system panel"
							loading="lazy"
							width="900"
							height="900"
						/>
					</figure>
				</div>
				<div class="narrative-copy" data-animate="fade-up">
					<h2 class="section-title">Designed for Safety. Delivered with Confidence.</h2>
					<p class="section-subtitle">
						From access control and CCTV to life-safety alarms, we deliver integrated systems that protect people,
						premises, and operations. Every installation is planned around compliance, practical usability, and
						long-term reliability.
					</p>
				</div>
			</div>
		</section>

		<ServiceWhyChooseSection
			title="Why Choose NEC Electrical for Your Design & Build?"
			description="Choosing a partner who manages both technical design and physical installation gives your project a clear commercial advantage at every stage."
			items={whyChooseItems}
		/>

		<ServiceFaqSection items={faqItems} />
	</main>

	<Footer links={homeAnchors} />
</Layout>

<style>
	.service-hero {
		position: relative;
		min-height: clamp(290px, 42vw, 380px);
		display: grid;
		align-items: end;
		overflow: clip;
	}

	.service-hero-bg,
	.service-hero-overlay {
		position: absolute;
		inset: 0;
	}

	.service-hero-bg {
		background: center 30% / cover no-repeat url('/images/service-security-hero.png');
	}

	.service-hero-overlay {
		background: linear-gradient(115deg, rgba(10, 18, 42, 0.62), rgba(10, 18, 42, 0.35));
	}

	.service-hero-content {
		position: relative;
		z-index: 1;
		color: var(--white);
		padding-bottom: clamp(1.4rem, 3vw, 2.5rem);
	}

	.crumbs {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.42rem;
		font: 400 0.88rem/1.2 'League Spartan', Arial, sans-serif;
	}

	.crumbs a {
		color: rgba(255, 255, 255, 0.86);
		transition: color 0.2s var(--motion-ease);
	}

	.crumbs a:hover {
		color: var(--white);
	}

	h1 {
		margin-top: 0.85rem;
		font-size: clamp(2.1rem, 6.8vw, 4.2rem);
		letter-spacing: -0.03em;
		line-height: 0.98;
		max-width: 9ch;
		color: var(--white);
	}

	.service-intro {
		background: var(--ghost-white);
	}

	.section-kicker {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font: 600 0.86rem/1 'League Spartan', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--blue);
	}

	.highlight-grid {
		margin-top: 2.5rem;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.95rem;
	}

	.highlight-card {
		position: relative;
		background: #ffffff;
		clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
		padding: 1.35rem 1.35rem 1.4rem;
		box-shadow: 0 10px 26px rgba(21, 27, 44, 0.06);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.highlight-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 18px 34px rgba(21, 27, 44, 0.14);
	}

	.icon-wrap {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.35rem;
		height: 3.35rem;
		border-radius: 50%;
		color: var(--white);
		background: linear-gradient(145deg, #2a34ff, #0000fe);
		transition: transform 0.25s ease;
	}

	.highlight-card:hover .icon-wrap {
		transform: translateY(-2px) scale(1.04);
	}

	.icon-wrap svg {
		width: 1.45rem;
		height: 1.45rem;
	}

	h3 {
		margin-top: 1.1rem;
		padding-top: 0.9rem;
		border-top: 1px solid rgba(0, 0, 254, 0.2);
		font-size: clamp(1.45rem, 2vw, 2rem);
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.highlight-card p {
		margin-top: 0.85rem;
		font-size: 0.98rem;
		line-height: 1.72;
		color: var(--charcoal-400);
	}

	@media (max-width: 1060px) {
		.highlight-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 640px) {
		.highlight-grid {
			grid-template-columns: 1fr;
		}
	}

	.security-narrative {
		background: var(--white);
	}

	.narrative-images {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.media-tile {
		margin: 0;
		clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 22px, 100% 100%, 0 100%);
		overflow: clip;
		background: #e8edf8;
	}

	.media-tile img {
		width: 100%;
		display: block;
		height: 300px;
		object-fit: cover;
		object-position: center;
	}

	.narrative-copy {
		margin-top: 2rem;
		max-width: 64ch;
	}

	.narrative-copy .section-title {
		font-size: clamp(2rem, 3.8vw, 3rem);
		line-height: 1.06;
	}

	.narrative-copy .section-subtitle {
		max-width: 62ch;
	}

	@media (max-width: 560px) {
		.narrative-images {
			grid-template-columns: 1fr;
		}
	}
</style>
