---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { navLinks } from '../data/home';
import { sitemapColumns } from '../data/sitemap';

const pageTitle = 'Site map | NEC Ltd Electrical';
const pageDescription =
	'A visual overview of every public page on the NEC Ltd Electrical website: services, company information, and policies.';
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="https://dotwall.dev/nec/sitemap/"
	ogImage="/images/hero-1.jpg"
>
	<Header links={navLinks} ctaHref="/#contact" />

	<main id="main-content">
		<section class="sitemap-hero">
			<div class="sitemap-hero-bg" aria-hidden="true"></div>
			<div class="sitemap-hero-overlay" aria-hidden="true"></div>
			<div class="container sitemap-hero-content">
				<p class="hero-kicker">Navigation</p>
				<h1>Site map</h1>
				<p>
					Every public destination in one place. Use the cards below to jump straight to services, company pages,
					or policies.
				</p>
			</div>
		</section>

		<section class="section sitemap-board">
			<div class="container">
				<p class="section-kicker">At a glance</p>
				<h2 class="section-title">Where everything lives</h2>
				<p class="section-subtitle">
					Three columns mirror how visitors think about the site: the homepage story, deep-dive service pages, and
					organisation-wide information.
				</p>

				<div class="sitemap-grid">
					{
						sitemapColumns.map((column) => (
							<article class="sitemap-column brand-line-box">
								<header class="sitemap-column-head">
									<p class="sitemap-kicker">{column.kicker}</p>
									<h3>{column.title}</h3>
									{column.intro && <p class="sitemap-intro">{column.intro}</p>}
								</header>
								<ul class="sitemap-links">
									{column.pages.map((page) => (
										<li>
											<a class="sitemap-link" href={page.href}>
												<span class="sitemap-link-title">{page.label}</span>
												{page.description && <span class="sitemap-link-desc">{page.description}</span>}
											</a>
										</li>
									))}
								</ul>
							</article>
						))
					}
				</div>
			</div>
		</section>
	</main>

	<Footer links={navLinks} />
</Layout>

<style>
	.sitemap-hero {
		position: relative;
		min-height: 44vh;
		overflow: clip;
		display: grid;
		align-items: end;
	}

	.sitemap-hero-bg,
	.sitemap-hero-overlay {
		position: absolute;
		inset: 0;
	}

	.sitemap-hero-bg {
		background: center / cover no-repeat url('/images/hero-1.jpg');
	}

	.sitemap-hero-overlay {
		background: linear-gradient(125deg, rgba(17, 22, 35, 0.88), rgba(17, 22, 35, 0.5));
	}

	.sitemap-hero-content {
		position: relative;
		z-index: 1;
		color: var(--white);
		padding-bottom: 2.5rem;
	}

	.hero-kicker {
		margin: 0;
		text-transform: uppercase;
		font: 600 0.78rem/1 'Open Sans', Arial, sans-serif;
		letter-spacing: 0.09em;
		color: rgba(255, 255, 255, 0.9);
	}

	h1 {
		margin-top: 0.85rem;
		font-size: clamp(2.1rem, 6vw, 3.6rem);
		line-height: 0.98;
		letter-spacing: -0.03em;
		color: var(--white);
	}

	.sitemap-hero-content p:last-child {
		margin-top: 1rem;
		max-width: 58ch;
		color: #dde1ee;
	}

	.sitemap-board {
		background: var(--ghost-white);
	}

	.sitemap-grid {
		margin-top: 1.75rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.1rem;
		align-items: stretch;
	}

	.sitemap-column {
		background: var(--white);
		clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 0 100%);
		padding: 1.25rem 1.15rem 1.35rem;
		box-shadow: 0 12px 28px rgba(20, 24, 38, 0.07);
		display: flex;
		flex-direction: column;
		min-height: 100%;
	}

	.sitemap-column-head {
		padding-bottom: 0.85rem;
		border-bottom: 1px solid rgba(30, 36, 56, 0.08);
	}

	.sitemap-kicker {
		margin: 0;
		font: 600 0.72rem/1 'Open Sans', Arial, sans-serif;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--blue);
	}

	.sitemap-column h3 {
		margin: 0.45rem 0 0;
		font-size: clamp(1.35rem, 2.2vw, 1.55rem);
		color: var(--charcoal-100);
		letter-spacing: -0.02em;
	}

	.sitemap-intro {
		margin: 0.55rem 0 0;
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--charcoal-400);
	}

	.sitemap-links {
		margin: 0.85rem 0 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex: 1;
	}

	.sitemap-link {
		display: block;
		padding: 0.65rem 0.75rem;
		background: #f5f7fb;
		color: var(--charcoal-100);
		text-decoration: none;
		clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
		transition: background-color 0.2s var(--motion-ease), color 0.2s var(--motion-ease), transform 0.2s
			var(--motion-ease);
	}

	.sitemap-link:hover {
		background: var(--blue);
		color: var(--white);
		transform: translateY(-2px);
	}

	.sitemap-link-title {
		display: block;
		font: 700 1rem/1.15 'League Spartan', Arial, sans-serif;
	}

	.sitemap-link-desc {
		display: block;
		margin-top: 0.28rem;
		font: 400 0.84rem/1.45 'Open Sans', Arial, sans-serif;
		color: var(--charcoal-400);
	}

	.sitemap-link:hover .sitemap-link-desc {
		color: rgba(255, 255, 255, 0.9);
	}

	@media (max-width: 1020px) {
		.sitemap-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
