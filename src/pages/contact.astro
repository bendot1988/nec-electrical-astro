---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import { navLinks } from '../data/home';

const pageTitle = 'Contact | NEC Ltd Electrical';
const pageDescription =
	'Contact NEC Ltd Electrical to discuss design and build electrical services, project scope, programme, and budget.';

const pageLinks = navLinks.map((link) => ({
	...link,
	href: link.href.startsWith('/') ? link.href : `/${link.href}`,
}));
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="https://dotwall.dev/nec/contact/"
	ogImage="/images/hero-1.jpg"
>
	<Header links={pageLinks} ctaHref="/contact/" />

	<main id="main-content">
		<section class="contact-hero">
			<div class="contact-hero-bg" aria-hidden="true"></div>
			<div class="contact-hero-overlay" aria-hidden="true"></div>
			<div class="container contact-hero-content">
				<p class="hero-kicker">Contact</p>
				<h1>Let&apos;s discuss your next electrical project</h1>
				<p>
					Whether you need design support, site delivery, or a complete design and build package, our team can
					help scope the right solution.
				</p>
			</div>
		</section>

		<ContactSection />
	</main>

	<Footer links={pageLinks} />
</Layout>

<style>
	.contact-hero {
		position: relative;
		min-height: 46vh;
		overflow: clip;
		display: grid;
		align-items: end;
	}

	.contact-hero-bg,
	.contact-hero-overlay {
		position: absolute;
		inset: 0;
	}

	.contact-hero-bg {
		background: center / cover no-repeat url('/images/hero-1.jpg');
	}

	.contact-hero-overlay {
		background: linear-gradient(130deg, rgba(17, 22, 35, 0.85), rgba(17, 22, 35, 0.48));
	}

	.contact-hero-content {
		position: relative;
		z-index: 1;
		color: var(--white);
		padding-bottom: 2.7rem;
	}

	.hero-kicker {
		margin: 0;
		text-transform: uppercase;
		font: 600 0.78rem/1 'Open Sans', Arial, sans-serif;
		letter-spacing: 0.09em;
		color: rgba(255, 255, 255, 0.9);
	}

	h1 {
		margin-top: 0.85rem;
		font-size: clamp(2.2rem, 6.2vw, 4.1rem);
		line-height: 0.98;
		letter-spacing: -0.03em;
		color: var(--white);
	}

	.contact-hero-content p:last-child {
		margin-top: 1rem;
		max-width: 64ch;
		color: #dde1ee;
	}
</style>
